set -euo pipefail

setup() {
    whereami=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")
    IMAGE=${IMAGE:-1121citrus/pfsense-backup:latest}
    chmod +x "${whereami}/bin/"*

    run_backup() {
        # shellcheck disable=SC2086  # DOCKER_RUN_ARGS is intentionally word-split
        docker run -i --rm ${DOCKER_RUN_ARGS:-} \
            -e "PATH=/test/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
            -e AWS_S3_BUCKET_NAME=test-bucket \
            -e PFSENSE_HOST=fake-host \
            -e PFSENSE_IDENTITY_FILE=/test/fixtures/pfsense-identity.key \
            -e PFSENSE_IDENTITY_PASSWORD=testpassword \
            -e COMPRESSION=none \
            -v "${whereami}/bin:/test/bin:ro" \
            -v "${whereami}/fixtures:/test/fixtures:ro" \
            -v "${whereami}/fixtures/test-path.sh:/etc/profile.d/test-path.sh:ro" \
            "$@" \
            "${IMAGE}" /usr/local/bin/backup 2>&1
    }
    export -f run_backup
}

test_backup_gpg_passphrase_env() {
    local output
    output=$(run_backup -e GPG_PASSPHRASE=test-passphrase) || {
        echo "FAIL '${FUNCNAME[0]}': command exited non-zero"; return 1
    }
    if [[ "${output}" == *'encrypting backup with GPG'* && "${output}" == *'.xml.gpg'* ]]; then
        echo "PASS '${FUNCNAME[0]}': GPG encrypts when GPG_PASSPHRASE env var is set"
    else
        echo "FAIL '${FUNCNAME[0]}': expected GPG encryption message and .xml.gpg extension. Got: '${output}'"
        return 1
    fi
}

test_backup_gpg_passphrase_with_spaces() {
    local output
    output=$(run_backup -e "GPG_PASSPHRASE=pass with spaces") || {
        echo "FAIL '${FUNCNAME[0]}': command exited non-zero"; return 1
    }
    if [[ "${output}" == *'encrypting backup with GPG'* && "${output}" == *'.xml.gpg'* ]]; then
        echo "PASS '${FUNCNAME[0]}': GPG encrypts when GPG_PASSPHRASE contains spaces"
    else
        echo "FAIL '${FUNCNAME[0]}': expected GPG encryption with space-containing passphrase. Got: '${output}'"
        return 1
    fi
}

test_backup_gpg_passphrase_file() {
    local output
    output=$(run_backup \
        -e GPG_PASSPHRASE_FILE=/test/fixtures/gpg-passphrase) || {
        echo "FAIL '${FUNCNAME[0]}': command exited non-zero"; return 1
    }
    if [[ "${output}" == *'encrypting backup with GPG'* && "${output}" == *'.xml.gpg'* ]]; then
        echo "PASS '${FUNCNAME[0]}': GPG encrypts when GPG_PASSPHRASE_FILE is a readable file"
    else
        echo "FAIL '${FUNCNAME[0]}': expected GPG encryption message and .xml.gpg extension. Got: '${output}'"
        return 1
    fi
}

test_backup_gpg_with_xz_compression() {
    local output
    output=$(run_backup \
        -e COMPRESSION=xz \
        -e GPG_PASSPHRASE=test-passphrase) || {
        echo "FAIL '${FUNCNAME[0]}': command exited non-zero"; return 1
    }
    if [[ "${output}" == *'.xml.xz.gpg'* ]]; then
        echo "PASS '${FUNCNAME[0]}': combined xz+GPG produces .xml.xz.gpg"
    else
        echo "FAIL '${FUNCNAME[0]}': expected .xml.xz.gpg extension. Got: '${output}'"
        return 1
    fi
}

test_backup_no_gpg_without_passphrase() {
    local output
    output=$(run_backup \
        -e GPG_PASSPHRASE= \
        -e GPG_PASSPHRASE_FILE=/nonexistent/gpg-passphrase) || {
        echo "FAIL '${FUNCNAME[0]}': command exited non-zero"; return 1
    }
    if [[ "${output}" != *'encrypting backup with GPG'* && "${output}" != *'.xml.gpg'* ]]; then
        echo "PASS '${FUNCNAME[0]}': no GPG encryption when neither passphrase source is available"
    else
        echo "FAIL '${FUNCNAME[0]}': unexpected GPG encryption. Got: '${output}'"
        return 1
    fi
}

run_tests() {
    local passed=0
    local tests=(
        test_backup_gpg_passphrase_env
        test_backup_gpg_passphrase_with_spaces
        test_backup_gpg_passphrase_file
        test_backup_gpg_with_xz_compression
        test_backup_no_gpg_without_passphrase
    )

    setup || { echo "ERROR: Setup failed"; return 1; }

    echo "Running tests for backup GPG encryption..."
    echo "============================================"

    for test in "${tests[@]}"; do
        if "${test}"; then (( passed += 1 )) || true; fi
    done

    local failed=$(( ${#tests[@]} - passed ))
    echo "============================================"
    echo "Results: ${passed} passed, ${failed} failed"
    return "${failed}"
}

[[ "${BASH_SOURCE[0]}" == "$0" ]] && run_tests
