set -euo pipefail

setup() {
    whereami=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")
    IMAGE=${IMAGE:-1121citrus/pfsense-backup:latest}
    chmod +x "${whereami}/bin/"*

    run_backup() {
        docker run -i --rm ${DOCKER_RUN_ARGS:-} \
            -e "PATH=/test/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
            -e AWS_S3_BUCKET_NAME=test-bucket \
            -e PFSENSE_HOST=fake-host \
            -e PFSENSE_IDENTITY_FILE=/test/fixtures/pfsense-identity.key \
            -e PFSENSE_IDENTITY_PASSWORD=testpassword \
            -v "${whereami}/bin:/test/bin:ro" \
            -v "${whereami}/fixtures:/test/fixtures:ro" \
            -v "${whereami}/fixtures/test-path.sh:/etc/profile.d/test-path.sh:ro" \
            "$@" \
            "${IMAGE}" /usr/local/bin/backup 2>&1
    }
    export -f run_backup
}

# Helper: assert that output contains an expected substring.
_assert_contains() {
    local description=$1 expected=$2 output=$3
    if [[ "${output}" == *"${expected}"* ]]; then
        echo "PASS '${FUNCNAME[1]}': ${description}"
    else
        echo "FAIL '${FUNCNAME[1]}': ${description} — expected '${expected}' in output"
        return 1
    fi
}

test_backup_no_compression() {
    local output
    output=$(run_backup -e COMPRESSION=none) || {
        echo "FAIL '${FUNCNAME[0]}': command exited non-zero"; return 1
    }
    _assert_contains "begins and finishes"     "begin backup"                             "${output}"
    _assert_contains "finishes cleanly"        "finish backup"                            "${output}"
    _assert_contains "invokes aws s3 mv"       "aws s3 mv"                                "${output}"
    _assert_contains "filename includes host"  "test-firewall-pfsense-v24.11-config-backup.xml" "${output}"
    _assert_contains "filename targets bucket" "test-bucket"                              "${output}"
}

test_backup_gz() {
    local output
    output=$(run_backup -e COMPRESSION=gz) || {
        echo "FAIL '${FUNCNAME[0]}': command exited non-zero"; return 1
    }
    _assert_contains "logs compression"  "compressing backup with gzip" "${output}"
    _assert_contains ".xml.gz extension" ".xml.gz"                      "${output}"
}

