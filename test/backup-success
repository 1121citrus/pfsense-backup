run_tests() {
    local passed=0
    local tests=(
        test_backup_no_compression
        test_backup_gz
        test_backup_gzip_alias
        test_backup_xz
        test_backup_lzma_alias
        test_backup_bzip2
        test_backup_bzip_alias
        test_backup_bzip3
        test_backup_lzop
        test_backup_lzo_alias
        test_backup_pigz
        test_backup_pixz
        test_backup_zip
    )

    setup || { echo "ERROR: Setup failed"; return 1; }

    echo "Running tests for backup success paths (all compression modes)..."
    echo "=================================================================="

    for test in "${tests[@]}"; do
        "${test}" && ((passed++)) || :
    done

    local failed=$(( ${#tests[@]} - passed ))
    echo "=================================================================="
    echo "Results: ${passed} passed, ${failed} failed"
    return "${failed}"
}

[[ "${BASH_SOURCE[0]}" == "$0" ]] && run_tests
