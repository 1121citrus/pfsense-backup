#!/usr/bin/env bash
# shellcheck shell=bash

# pfsense-backup: test that aws s3 mv failures are detected and reported.
#
# These tests verify two critical properties:
#   1. The backup script exits non-zero when aws s3 mv fails.
#   2. The healthcheck success marker is NOT created on a failed upload.
#
# The aws stub (test/bin/aws) is driven into failure mode by setting
# AWS_EXIT_CODE to a non-zero value.
#
# Copyright (C) 2025 James Hanlon [mailto:jim@hanlonsoftware.com]
# SPDX-License-Identifier: AGPL-3.0-or-later

set -euo pipefail

setup() {
    whereami=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")
    IMAGE=${IMAGE:-1121citrus/pfsense-backup:latest}
    chmod +x "${whereami}/bin/"*

    # Base docker run invocation — identical to other test suites except
    # COMPRESSION=none is fixed (compression mode is orthogonal to this test).
    run_backup() {
        # shellcheck disable=SC2086  # DOCKER_RUN_ARGS is intentionally word-split
        docker run -i --rm ${DOCKER_RUN_ARGS:-} \
            -e "PATH=/test/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
            -e AWS_S3_BUCKET_NAME=test-bucket \
            -e PFSENSE_HOST=fake-host \
            -e PFSENSE_IDENTITY_FILE=/test/fixtures/pfsense-identity.key \
            -e PFSENSE_IDENTITY_PASSWORD=testpassword \
            -e COMPRESSION=none \
            -v "${whereami}/bin:/test/bin:ro" \
            -v "${whereami}/fixtures:/test/fixtures:ro" \
            -v "${whereami}/fixtures/test-path.sh:/etc/profile.d/test-path.sh:ro" \
            "$@" \
            "${IMAGE}" /usr/local/bin/backup 2>&1
    }
    export -f run_backup
}

# Test 1: script exits non-zero when aws s3 mv returns an error.
test_backup_aws_upload_failure_exits_nonzero() {
    local result
    run_backup -e AWS_EXIT_CODE=1 >/dev/null && result=0 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero when aws s3 mv fails"
    else
        echo "FAIL '${FUNCNAME[0]}': should have exited non-zero on aws upload failure"
        return 1
    fi
}

# Test 2: the healthcheck success marker must NOT be created when aws fails.
#
# A writable tmpdir is bind-mounted into the container at /tmp/markers so we
# can inspect whether the marker file was created after the container exits.
test_backup_aws_upload_failure_no_success_marker() {
    local result tmpdir
    tmpdir=$(mktemp -d)
    # shellcheck disable=SC2064
    trap "rm -rf '${tmpdir}'" RETURN

    # shellcheck disable=SC2086  # DOCKER_RUN_ARGS is intentionally word-split
    docker run -i --rm ${DOCKER_RUN_ARGS:-} \
        -e "PATH=/test/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
        -e AWS_S3_BUCKET_NAME=test-bucket \
        -e PFSENSE_HOST=fake-host \
        -e PFSENSE_IDENTITY_FILE=/test/fixtures/pfsense-identity.key \
        -e PFSENSE_IDENTITY_PASSWORD=testpassword \
        -e COMPRESSION=none \
        -e AWS_EXIT_CODE=1 \
        -e HEALTHCHECK_SUCCESS_FILE=/tmp/markers/last-success \
        -v "${whereami}/bin:/test/bin:ro" \
        -v "${whereami}/fixtures:/test/fixtures:ro" \
        -v "${whereami}/fixtures/test-path.sh:/etc/profile.d/test-path.sh:ro" \
        -v "${tmpdir}:/tmp/markers" \
        "${IMAGE}" /usr/local/bin/backup >/dev/null 2>&1 && result=0 || result=$?

    if [[ ${result} -ne 0 && ! -f "${tmpdir}/last-success" ]]; then
        echo "PASS '${FUNCNAME[0]}': healthcheck success marker not created on aws upload failure"
    elif [[ -f "${tmpdir}/last-success" ]]; then
        echo "FAIL '${FUNCNAME[0]}': healthcheck success marker was created despite aws upload failure"
        return 1
    else
        echo "FAIL '${FUNCNAME[0]}': backup exited 0 despite aws upload failure (exit=${result})"
        return 1
    fi
}

# Test 3: the error output mentions the failure clearly.
test_backup_aws_upload_failure_error_message() {
    local output result
    output=$(run_backup -e AWS_EXIT_CODE=1) && result=0 || result=$?
    if [[ ${result} -ne 0 && "${output}" == *'aws s3 mv failed'* ]]; then
        echo "PASS '${FUNCNAME[0]}': output contains 'aws s3 mv failed' on upload failure"
    else
        echo "FAIL '${FUNCNAME[0]}': expected non-zero exit and 'aws s3 mv failed' in output. Got: '${output}'"
        return 1
    fi
}

# Test 4: success marker IS created when aws succeeds (sanity / regression guard).
test_backup_aws_success_creates_marker() {
    local result tmpdir
    tmpdir=$(mktemp -d)
    # shellcheck disable=SC2064
    trap "rm -rf '${tmpdir}'" RETURN

    # shellcheck disable=SC2086  # DOCKER_RUN_ARGS is intentionally word-split
    docker run -i --rm ${DOCKER_RUN_ARGS:-} \
        -e "PATH=/test/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
        -e AWS_S3_BUCKET_NAME=test-bucket \
        -e PFSENSE_HOST=fake-host \
        -e PFSENSE_IDENTITY_FILE=/test/fixtures/pfsense-identity.key \
        -e PFSENSE_IDENTITY_PASSWORD=testpassword \
        -e COMPRESSION=none \
        -e HEALTHCHECK_SUCCESS_FILE=/tmp/markers/last-success \
        -v "${whereami}/bin:/test/bin:ro" \
        -v "${whereami}/fixtures:/test/fixtures:ro" \
        -v "${whereami}/fixtures/test-path.sh:/etc/profile.d/test-path.sh:ro" \
        -v "${tmpdir}:/tmp/markers" \
        "${IMAGE}" /usr/local/bin/backup >/dev/null 2>&1 && result=0 || result=$?

    if [[ ${result} -eq 0 && -f "${tmpdir}/last-success" ]]; then
        echo "PASS '${FUNCNAME[0]}': healthcheck success marker created on successful upload"
    else
        echo "FAIL '${FUNCNAME[0]}': expected exit 0 and success marker file. exit=${result} marker=$(ls "${tmpdir}" 2>/dev/null || echo '(empty)')"
        return 1
    fi
}

run_tests() {
    local passed=0
    local tests=(
        test_backup_aws_upload_failure_exits_nonzero
        test_backup_aws_upload_failure_no_success_marker
        test_backup_aws_upload_failure_error_message
        test_backup_aws_success_creates_marker
    )

    setup || { echo "ERROR: Setup failed"; return 1; }

    echo "Running tests for aws upload failure handling..."
    echo "================================================="

    for test in "${tests[@]}"; do
        if "${test}"; then (( passed += 1 )) || true; fi
    done

    local failed=$(( ${#tests[@]} - passed ))
    echo "================================================="
    echo "Results: ${passed} passed, ${failed} failed"
    return "${failed}"
}

[[ "${BASH_SOURCE[0]}" == "$0" ]] && run_tests
