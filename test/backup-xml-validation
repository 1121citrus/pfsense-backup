#!/usr/bin/env bash

# pfsense-backup: test XML field validation in src/backup.
#
# SSH_FIXTURE_FILE is forwarded to the ssh stub to select a specific fixture.
#
# Copyright (C) 2025 James Hanlon [mailto:jim@hanlonsoftware.com]
# SPDX-License-Identifier: AGPL-3.0-or-later

set -euo pipefail

setup() {
    whereami=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")
    IMAGE=${IMAGE:-1121citrus/pfsense-backup:latest}
    chmod +x "${whereami}/bin/"*

    run_backup() {
        # shellcheck disable=SC2086  # DOCKER_RUN_ARGS is intentionally word-split
        docker run -i --rm ${DOCKER_RUN_ARGS:-} \
            -e "PATH=/test/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
            -e AWS_S3_BUCKET_NAME=test-bucket \
            -e PFSENSE_HOST=fake-host \
            -e PFSENSE_IDENTITY_FILE=/test/fixtures/pfsense-identity.key \
            -e PFSENSE_IDENTITY_PASSWORD=testpassword \
            -e COMPRESSION=none \
            -v "${whereami}/bin:/test/bin:ro" \
            -v "${whereami}/fixtures:/test/fixtures:ro" \
            -v "${whereami}/fixtures/test-path.sh:/etc/profile.d/test-path.sh:ro" \
            "$@" \
            "${IMAGE}" /usr/local/bin/backup 2>&1
    }
    export -f run_backup
}

test_backup_xml_missing_version() {
    local output result
    output=$(run_backup \
        -e SSH_FIXTURE_FILE=/test/fixtures/config-missing-version.xml 2>&1) && result=0 || result=$?
    if [[ ${result} -ne 0 && "${output}" == *'missing version'* ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero and reports missing version"
    else
        echo "FAIL '${FUNCNAME[0]}': expected non-zero exit and 'missing version' message. Got: '${output}'"
        return 1
    fi
}

test_backup_xml_missing_hostname() {
    local output result
    output=$(run_backup \
        -e SSH_FIXTURE_FILE=/test/fixtures/config-missing-hostname.xml 2>&1) && result=0 || result=$?
    if [[ ${result} -ne 0 && "${output}" == *'missing hostname'* ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero and reports missing hostname"
    else
        echo "FAIL '${FUNCNAME[0]}': expected non-zero exit and 'missing hostname' message. Got: '${output}'"
        return 1
    fi
}

test_backup_xml_missing_domain() {
    local output result
    output=$(run_backup \
        -e SSH_FIXTURE_FILE=/test/fixtures/config-missing-domain.xml 2>&1) && result=0 || result=$?
    if [[ ${result} -ne 0 && "${output}" == *'missing domain'* ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero and reports missing domain"
    else
        echo "FAIL '${FUNCNAME[0]}': expected non-zero exit and 'missing domain' message. Got: '${output}'"
        return 1
    fi
}

test_backup_xml_valid_filename() {
    local output result
    output=$(run_backup 2>&1) && result=0 || result=$?
    if [[ ${result} -eq 0 && "${output}" =~ test-firewall-pfsense-v24\.11-config-backup\.xml ]]; then
        echo "PASS '${FUNCNAME[0]}': backup filename contains host, version, and suffix"
    else
        echo "FAIL '${FUNCNAME[0]}': expected exit 0 and matching filename in output. Got: '${output}'"
        return 1
    fi
}

run_tests() {
    local passed=0
    local tests=(
        test_backup_xml_missing_version
        test_backup_xml_missing_hostname
        test_backup_xml_missing_domain
        test_backup_xml_valid_filename
    )

    setup || { echo "ERROR: Setup failed"; return 1; }

    echo "Running tests for backup XML field validation..."
    echo "================================================="

    for test in "${tests[@]}"; do
        if "${test}"; then (( passed += 1 )) || true; fi
    done

    local failed=$(( ${#tests[@]} - passed ))
    echo "================================================="
    echo "Results: ${passed} passed, ${failed} failed"
    return "${failed}"
}

[[ "${BASH_SOURCE[0]}" == "$0" ]] && run_tests
