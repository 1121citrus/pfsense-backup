#!/usr/bin/env bash
# shellcheck shell=bash

# pfsense-backup: end-to-end staging tests against live systems.
#
# These tests require a real pfSense host, real AWS credentials, or both.
# They are NOT run in CI.  See test/TESTING.md for setup and usage.
#
# Copyright (C) 2025 James Hanlon [mailto:jim@hanlonsoftware.com]
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# SYNOPSIS
#   test/staging [options] [IMAGE]
#
# OPTIONS
#   IMAGE                         Docker image to test (positional; also --image)
#   --image IMAGE                 Docker image to test (env: IMAGE)
#   --host HOST                   pfSense hostname or IP (env: PFSENSE_HOST)
#   --user USER                   SSH username (env: PFSENSE_USER;
#                                 default: remote-backup)
#   --identity-file FILE          SSH identity file (env: PFSENSE_IDENTITY_FILE)
#   --identity-password PASS      SSH identity passphrase (env: PFSENSE_IDENTITY_PASSWORD)
#   --identity-password-file FILE File containing the SSH passphrase
#                                 (env: PFSENSE_IDENTITY_PASSWORD_FILE)
#   --compression FORMAT          Backup compression format (env: COMPRESSION)
#   --bucket BUCKET               S3 bucket for backup uploads (env: AWS_S3_BUCKET_NAME)
#   --aws-config FILE             AWS config file path
#                                 (env: AWS_CONFIG_FILE;
#                                 default: ~/.secrets/aws-config)
#   --aws-credentials FILE        AWS credentials file path
#                                 (env: AWS_CREDENTIALS_FILE;
#                                 default: ~/.secrets/aws-credentials)
#   --dryrun                      Enable S3 dry-run (env: AWS_DRYRUN; default: auto)
#   --no-dryrun                   Disable S3 dry-run (write real objects)
#   --scan                        Run Trivy HIGH/CRITICAL scan (default)
#   --no-scan                     Skip Trivy scan; implies --no-advise unless
#                                 --advise is given explicitly
#   --no-coverage                 Skip the kcov bash coverage report (advisory only)
#   --advise [LIST]               Run advisory scans: coverage,grype,scout,dive,all
#                                 (default with no list given: all)
#                                 Advisory scans are off by default.
#   --no-advise                   Disable all advisory scans
#   --cache CACHE_RULES           One-run cache controls for scanner DBs.
#                                 Rule format: 'reset=<targets>;skip-update=<targets>'
#                                 Targets: trivy, grype, all (comma-delimited)
#                                 Examples:
#                                   --cache 'reset=all'
#                                   --cache 'skip-update=grype'
#                                   --cache 'reset=grype;skip-update=trivy'
#   --yes                         Skip the "yes" confirmation prompt
#   --test TEST                   Run only the named test function
#   -h, --help                    Print this message and exit
#
# ENVIRONMENT
#   IMAGE                         Docker image to test
#   AWS_S3_BUCKET_NAME            S3 bucket for backup uploads
#   AWS_CONFIG_FILE               Path to AWS config file
#                                 (default: ~/.secrets/aws-config)
#   AWS_CREDENTIALS_FILE          Path to AWS credentials file
#                                 (default: ~/.secrets/aws-credentials)
#   AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
#                                 Inline AWS credentials (alternative to config files)
#   AWS_DRYRUN                    true = no real S3 writes; false = live writes
#   STAGING_SCAN                  true/false — controls Trivy scan (default: true)
#   DOCKER_RUN_ARGS               Extra flags appended to every docker run invocation
#   PFSENSE_HOST                  pfSense hostname or IP
#   PFSENSE_USER                  SSH username (default: remote-backup)
#   PFSENSE_IDENTITY_FILE         Path to SSH identity file
#   PFSENSE_IDENTITY_PASSWORD     Passphrase for the SSH identity (or a readable
#                                 file path, treated as PFSENSE_IDENTITY_PASSWORD_FILE)
#   PFSENSE_IDENTITY_PASSWORD_FILE
#                                 Path to a file containing the SSH passphrase
#   COMPRESSION                   Backup compression format (optional)
#
# EXAMPLES
#   # Image-only smoke tests (no credentials needed):
#   test/staging 1121citrus/pfsense-backup:latest
#
#   # Quick iteration — skip scan:
#   test/staging --no-scan 1121citrus/pfsense-backup:latest
#
#   # Full test suite against a live pfSense host and S3 bucket:
#   test/staging \
#       --host 192.168.1.1 \
#       --identity-file ~/.ssh/pfsense_id \
#       --identity-password-file ~/.secrets/pfsense-password \
#       --bucket test.my-backups \
#       --aws-config ~/.secrets/aws-config \
#       --aws-credentials ~/.secrets/aws-credentials \
#       1121citrus/pfsense-backup:latest
#
#   # Skip confirmation prompt (CI / scripted use):
#   test/staging --host 192.168.1.1 --identity-file ~/.ssh/pfsense_id \
#       --identity-password-file ~/.secrets/pfsense-password \
#       --bucket test.my-backups --yes \
#       1121citrus/pfsense-backup:latest
#
#   # Reset scanner DB caches for this run, then skip Grype DB update:
#   test/staging --cache 'reset=all;skip-update=grype' \
#       1121citrus/pfsense-backup:latest
#
#   # Run only the cron test:
#   test/staging --test test_staging_cron_fires \
#       1121citrus/pfsense-backup:latest

set -euo pipefail

# ---------------------------------------------------------------------------
# Defaults — overridden by environment variables, then by CLI flags.
# ---------------------------------------------------------------------------
IMAGE="${IMAGE:-}"
PFSENSE_HOST="${PFSENSE_HOST:-}"
PFSENSE_USER="${PFSENSE_USER:-}"
PFSENSE_IDENTITY_FILE="${PFSENSE_IDENTITY_FILE:-}"
PFSENSE_IDENTITY_PASSWORD="${PFSENSE_IDENTITY_PASSWORD:-}"
PFSENSE_IDENTITY_PASSWORD_FILE="${PFSENSE_IDENTITY_PASSWORD_FILE:-}"
COMPRESSION="${COMPRESSION:-}"
AWS_S3_BUCKET_NAME="${AWS_S3_BUCKET_NAME:-}"
AWS_CONFIG_FILE="${AWS_CONFIG_FILE:-}"
AWS_CREDENTIALS_FILE="${AWS_CREDENTIALS_FILE:-}"
DOCKER_RUN_ARGS="${DOCKER_RUN_ARGS:-}"
_YES=false
_ONLY_TEST=""
_SCAN="${STAGING_SCAN:-true}"
_ADVISE_COVERAGE=false
_ADVISE_DIVE=false
_ADVISE_GRYPE=false
_ADVISE_SCOUT=false
_ADVISE_EXPLICIT=false
_CACHE_RESET_TRIVY=false
_CACHE_RESET_GRYPE=false
_CACHE_SKIP_UPDATE_TRIVY=false
_CACHE_SKIP_UPDATE_GRYPE=false

# Tool image refs — keep in sync with the top-level build script.
BATS_KCOV_IMAGE=1121citrus/bats-kcov
BATS_KCOV_TAG=latest
DIVE_IMAGE=wagoodman/dive
DIVE_TAG=v0.13.1
GRYPE_IMAGE=anchore/grype
GRYPE_TAG=v0.87.0
TRIVY_IMAGE=aquasec/trivy
TRIVY_TAG=0.62.1

TRIVY_CACHE_VOLUME=pfsense-backup-staging-trivy-cache
GRYPE_CACHE_VOLUME=pfsense-backup-staging-grype-cache

_set_cache_targets() {
    local mode="$1" targets_csv="$2" target
    IFS=',' read -ra _tgts <<< "${targets_csv,,}"
    for target in "${_tgts[@]}"; do
        case "${target}" in
            trivy)
                if [[ "${mode}" == "reset" ]];       then _CACHE_RESET_TRIVY=true; fi
                if [[ "${mode}" == "skip-update" ]]; then _CACHE_SKIP_UPDATE_TRIVY=true; fi
                ;;
            grype)
                if [[ "${mode}" == "reset" ]];       then _CACHE_RESET_GRYPE=true; fi
                if [[ "${mode}" == "skip-update" ]]; then _CACHE_SKIP_UPDATE_GRYPE=true; fi
                ;;
            all)
                if [[ "${mode}" == "reset" ]]; then
                    _CACHE_RESET_TRIVY=true; _CACHE_RESET_GRYPE=true
                fi
                if [[ "${mode}" == "skip-update" ]]; then
                    _CACHE_SKIP_UPDATE_TRIVY=true; _CACHE_SKIP_UPDATE_GRYPE=true
                fi
                ;;
            *) echo "Unknown cache target: ${target}" >&2; exit 1 ;;
        esac
    done
}

_parse_cache_rules() {
    local rules="$1" entry key value
    IFS=';' read -ra _rules <<< "${rules}"
    for entry in "${_rules[@]}"; do
        key="${entry%%=*}"; value="${entry#*=}"
        key="${key,,}"; key="${key// /}"; value="${value// /}"
        if [[ "${entry}" != *=* || -z "${key}" || -z "${value}" ]]; then
            echo "Invalid --cache rule: ${entry}" >&2; exit 1
        fi
        case "${key}" in
            reset|skip-update) _set_cache_targets "${key}" "${value}" ;;
            *) echo "Unknown --cache rule key: ${key}" >&2; exit 1 ;;
        esac
    done
}

_reset_cache_db() {
    local volume_name="$1"
    docker run --rm \
        -v "${volume_name}:/cache" \
        alpine:3.21 \
        sh -c "rm -rf /cache/* && mkdir -p /cache"
}

show_help() {
    # Extract the header comment from SYNOPSIS through EXAMPLES (inclusive).
    sed -n '/^# SYNOPSIS/,/^set -/p' "$0" \
        | grep '^#' \
        | sed 's/^# \{0,1\}//'
}

# ---------------------------------------------------------------------------
# Setup
# ---------------------------------------------------------------------------

setup() {
    [[ -n "${IMAGE}" ]] || {
        echo "ERROR: IMAGE is not set" >&2
        echo "       Pass it as a positional arg or use --image IMAGE" >&2
        return 1
    }
    if ! docker image inspect "${IMAGE}" >/dev/null 2>&1; then
        echo "ERROR: image '${IMAGE}' not found in local Docker daemon" >&2
        echo "       Build it first with: ./build" >&2
        return 1
    fi
    if ! docker run --rm --entrypoint /bin/sh \
           "${IMAGE}" -c 'test -x /usr/local/bin/backup' 2>/dev/null; then
        echo "ERROR: /usr/local/bin/backup missing or not executable in '${IMAGE}'" >&2
        return 1
    fi

    # Resolve the AWS config file path once so each test does not re-derive it.
    _aws_cfg="${AWS_CONFIG_FILE:-${HOME}/.secrets/aws-config}"

    # The image runs as a non-root user (UID 10001).  A mode-600 file owned by
    # the host user is unreadable inside the container.  Create a world-readable
    # temp copy for the duration of the test run.
    _aws_cfg_mount="${_aws_cfg}"
    if [[ -r "${_aws_cfg}" ]]; then
        _aws_cfg_mount=$(mktemp /tmp/aws-config-staging-XXXXXX)
        cp "${_aws_cfg}" "${_aws_cfg_mount}"
        chmod 0644 "${_aws_cfg_mount}"
    fi
    export _aws_cfg_mount

    # Resolve the AWS credentials file; create a world-readable temp copy for
    # the non-root container user (UID 10001), same as the config file above.
    _aws_creds="${AWS_CREDENTIALS_FILE:-${HOME}/.secrets/aws-credentials}"
    _aws_creds_mount="${_aws_creds}"
    if [[ -r "${_aws_creds}" ]]; then
        _aws_creds_mount=$(mktemp /tmp/aws-credentials-staging-XXXXXX)
        cp "${_aws_creds}" "${_aws_creds_mount}"
        chmod 0644 "${_aws_creds_mount}"
    fi
    export _aws_creds _aws_creds_mount

    # Create a shared image archive for Trivy, Grype, and Dive — avoids mounting
    # the Docker socket inside scanner containers, which hangs on macOS Docker Desktop.
    _scan_tar=""
    if [[ "${_SCAN}" == "true" || "${_ADVISE_GRYPE}" == "true" \
            || "${_ADVISE_DIVE}" == "true" ]]; then
        _scan_tar=$(mktemp /tmp/staging-scan-XXXXXX)
        docker save "${IMAGE}" > "${_scan_tar}"
    fi
    export _scan_tar

    # Clean up temp files on exit (world-readable credential copies + scan archive).
    # shellcheck disable=SC2064
    trap 'rm -f "${_aws_cfg_mount}" "${_aws_creds_mount}" "${_scan_tar}"' EXIT
}

# ---------------------------------------------------------------------------
# Helpers — skip / availability guards
# ---------------------------------------------------------------------------

# _skip: print a SKIP notice, increment the shared skip counter, and return 0
# so the test is not counted as a failure.
_SKIP_COUNT=0
_skip() { echo "SKIP '${FUNCNAME[1]}': $*"; (( ++_SKIP_COUNT )) || true; }

# _pfsense_available: true when PFSENSE_HOST and a usable credential exist.
_pfsense_available() {
    local pw_file="${PFSENSE_IDENTITY_PASSWORD_FILE:-/run/secrets/pfsense-identity-password}"
    [[ -n "${PFSENSE_HOST:-}" ]] && \
        [[ -n "${PFSENSE_IDENTITY_FILE:-}" ]] && \
        { [[ -n "${PFSENSE_IDENTITY_PASSWORD:-}" ]] || [[ -r "${pw_file}" ]]; }
}

# _aws_available: true when bucket and credentials are configured.
_aws_available() {
    [[ -n "${AWS_S3_BUCKET_NAME:-}" ]] && \
        { [[ -r "${_aws_cfg_mount:-/nonexistent}" ]] || \
          [[ -r "${_aws_creds_mount:-/nonexistent}" ]] || \
          [[ -n "${AWS_ACCESS_KEY_ID:-}" ]]; }
}

# _service_available: true when both pfSense and AWS are available.
_service_available() {
    _pfsense_available && _aws_available
}

# ---------------------------------------------------------------------------
# Test runner helpers
# ---------------------------------------------------------------------------

# _append_pfsense_args: append pfSense credential flags to a named array.
#
# Handles the common mistake of setting PFSENSE_IDENTITY_PASSWORD to a file
# path instead of the actual passphrase string.  When the value is a
# readable path it is treated as PFSENSE_IDENTITY_PASSWORD_FILE and
# bind-mounted into the container rather than passed inline.
_append_pfsense_args() {
    local -n _ref=$1   # nameref to the caller's extra_args array
    if [[ -n "${PFSENSE_HOST:-}" ]]; then
        _ref+=(-e "PFSENSE_HOST=${PFSENSE_HOST}")
        # If PFSENSE_HOST is a hostname (not an IP), resolve it on the host
        # and inject the mapping into the container via --add-host.  Docker
        # containers have their own DNS and cannot see the host's /etc/hosts
        # or mDNS, so hostnames that resolve locally will fail inside the
        # container without this injection.
        if ! [[ "${PFSENSE_HOST}" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            local _resolved
            _resolved=$(python3 -c \
                "import socket; print(socket.gethostbyname('${PFSENSE_HOST}'))" \
                2>/dev/null) \
                || _resolved=$(getent hosts "${PFSENSE_HOST}" 2>/dev/null \
                    | awk '{print $1; exit}') \
                || true
            [[ -n "${_resolved}" ]] && \
                _ref+=(--add-host "${PFSENSE_HOST}:${_resolved}")
        fi
    fi
    [[ -n "${PFSENSE_USER:-}" ]] && \
        _ref+=(-e "PFSENSE_USER=${PFSENSE_USER}")
    [[ -n "${PFSENSE_IDENTITY_FILE:-}" ]] && \
        _ref+=(-e "PFSENSE_IDENTITY_FILE=${PFSENSE_IDENTITY_FILE}" \
               -v "${PFSENSE_IDENTITY_FILE}:${PFSENSE_IDENTITY_FILE}:ro")
    if [[ -n "${PFSENSE_IDENTITY_PASSWORD:-}" ]]; then
        if [[ -r "${PFSENSE_IDENTITY_PASSWORD}" ]]; then
            # Readable path — bind-mount and use file-based auth.
            # (Likely set PFSENSE_IDENTITY_PASSWORD to a file path when
            # PFSENSE_IDENTITY_PASSWORD_FILE was intended.)
            _ref+=(-e "PFSENSE_IDENTITY_PASSWORD_FILE=${PFSENSE_IDENTITY_PASSWORD}" \
                   -v "${PFSENSE_IDENTITY_PASSWORD}:${PFSENSE_IDENTITY_PASSWORD}:ro")
        else
            _ref+=(-e "PFSENSE_IDENTITY_PASSWORD=${PFSENSE_IDENTITY_PASSWORD}")
        fi
    fi
    [[ -n "${PFSENSE_IDENTITY_PASSWORD_FILE:-}" ]] && \
        [[ -r "${PFSENSE_IDENTITY_PASSWORD_FILE}" ]] && \
        _ref+=(-e "PFSENSE_IDENTITY_PASSWORD_FILE=${PFSENSE_IDENTITY_PASSWORD_FILE}" \
               -v "${PFSENSE_IDENTITY_PASSWORD_FILE}:${PFSENSE_IDENTITY_PASSWORD_FILE}:ro")
}

# run_backup: docker run wrapper for the backup script.
# Extra docker flags may be passed as arguments.
run_backup() {
    local extra_args=()
    _append_pfsense_args extra_args
    [[ -n "${AWS_S3_BUCKET_NAME:-}" ]] && \
        extra_args+=(-e "AWS_S3_BUCKET_NAME=${AWS_S3_BUCKET_NAME}")
    if [[ -r "${_aws_cfg_mount:-/nonexistent}" ]]; then
        extra_args+=(-e "AWS_CONFIG_FILE=/run/secrets/aws-config" \
                     -v "${_aws_cfg_mount}:/run/secrets/aws-config:ro")
    fi
    if [[ -r "${_aws_creds_mount:-/nonexistent}" ]]; then
        extra_args+=(-e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials" \
                     -v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro")
    fi
    [[ -n "${AWS_ACCESS_KEY_ID:-}" ]] && \
        extra_args+=(-e "AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}" \
                     -e "AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY:-}" \
                     -e "AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-}")
    [[ -n "${AWS_DRYRUN:-}" ]] && \
        extra_args+=(-e "AWS_DRYRUN=${AWS_DRYRUN}")
    [[ -n "${COMPRESSION:-}" ]] && \
        extra_args+=(-e "COMPRESSION=${COMPRESSION}")
    [[ -n "${DEBUG:-}" ]] && \
        extra_args+=(-e "DEBUG=${DEBUG}")
    [[ -n "${LOG_LEVEL:-}" ]] && \
        extra_args+=(-e "LOG_LEVEL=${LOG_LEVEL}")
    # shellcheck disable=SC2086
    docker run --rm ${DOCKER_RUN_ARGS:-} "${extra_args[@]}" "$@" \
        -e "AWS_RETRY_MODE=standard" \
        -e "AWS_MAX_ATTEMPTS=5" \
        "${IMAGE}" /usr/local/bin/backup 2>&1
}

# _aws: run an aws CLI command inside the image, bypassing the backup entrypoint.
# Used for bucket setup/teardown in tests.  Includes retry env vars for
# transient S3 failures (throttle errors, 5xx, connection resets).
_aws() {
    local aws_mounts=() aws_env=()
    if [[ -r "${_aws_cfg_mount:-/nonexistent}" ]]; then
        aws_mounts+=(-v "${_aws_cfg_mount}:/run/secrets/aws-config:ro")
        aws_env+=(-e "AWS_CONFIG_FILE=/run/secrets/aws-config")
    fi
    if [[ -r "${_aws_creds_mount:-/nonexistent}" ]]; then
        aws_mounts+=(-v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro")
        aws_env+=(-e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials")
    fi
    # shellcheck disable=SC2086
    docker run --rm --entrypoint /usr/bin/aws \
        ${DOCKER_RUN_ARGS:-} \
        "${aws_mounts[@]}" \
        "${aws_env[@]}" \
        -e "AWS_RETRY_MODE=standard" \
        -e "AWS_MAX_ATTEMPTS=5" \
        "${IMAGE}" "$@"
}

# _healthcheck_run: run /usr/local/bin/healthcheck inside the container
# after executing the given setup shell fragment.  Remaining arguments are
# extra docker flags (-e, -v, etc.).  Returns the docker exit code; all
# container output is suppressed (we only care about the exit status).
_healthcheck_run() {
    local script="$1"; shift
    docker run --rm --entrypoint /bin/bash \
        "$@" \
        "${IMAGE}" -c "${script}" \
        >/dev/null 2>&1
}

