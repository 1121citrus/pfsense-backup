# ---------------------------------------------------------------------------
# Tests — pfSense-dependent (require a live pfSense host)
# ---------------------------------------------------------------------------

test_staging_backup_downloads_config() {
    _pfsense_available || { _skip "PFSENSE_HOST / identity not configured"; return 0; }
    local output result=0
    output=$(run_backup \
        -e AWS_S3_BUCKET_NAME=test-bucket \
        -e AWS_DRYRUN=true \
        2>&1) && result=0 || result=$?
    if [[ ${result} -eq 0 ]] && \
       [[ "${output}" == *'finish backup'* ]]; then
        echo "PASS '${FUNCNAME[0]}': backup completed against live pfSense"
    else
        echo "FAIL '${FUNCNAME[0]}': expected 'finish backup' in output"
        printf '%s\n' "${output}" | tail -20 >&2
        return 1
    fi
}

test_staging_backup_xml_has_expected_fields() {
    _pfsense_available || { _skip "PFSENSE_HOST / identity not configured"; return 0; }
    local output result=0
    output=$(run_backup \
        -e AWS_S3_BUCKET_NAME=test-bucket \
        -e AWS_DRYRUN=true \
        2>&1) && result=0 || result=$?
    # The backup filename embeds hostname and version — their presence in the
    # log confirms that XML field extraction succeeded.
    if [[ ${result} -eq 0 ]] && \
       [[ "${output}" == *'-pfsense-v'* ]] && \
       [[ "${output}" == *'-config-backup.xml'* ]]; then
        echo "PASS '${FUNCNAME[0]}': backup filename contains hostname and version fields"
    else
        echo "FAIL '${FUNCNAME[0]}': expected hostname/version in backup filename"
        printf '%s\n' "${output}" | tail -20 >&2
        return 1
    fi
}

# ---------------------------------------------------------------------------
# Tests — full pipeline (pfSense + AWS)
# ---------------------------------------------------------------------------

# test_staging_backup_direct: run backup end-to-end with real pfSense + AWS.
# Provides progress feedback every 10 s because the SSH + upload may take
# 30–90 s on a slow connection.
test_staging_backup_direct() {
    _service_available || { _skip "pfSense or AWS not configured"; return 0; }

    local tmpout
    tmpout=$(mktemp)
    # shellcheck disable=SC2064
    trap "rm -f '${tmpout}'" RETURN

    run_backup >"${tmpout}" 2>&1 &
    local pid=$!

    local elapsed=0 interval=10 timeout=300
    while kill -0 "${pid}" 2>/dev/null; do
        sleep "${interval}"
        elapsed=$(( elapsed + interval ))
        printf '[%ds] backup in progress...\n' "${elapsed}"
        if (( elapsed >= timeout )); then
            kill "${pid}" 2>/dev/null || true
            echo "FAIL '${FUNCNAME[0]}': timed out after ${timeout}s"
            cat "${tmpout}" >&2
            return 1
        fi
    done
    local result
    wait "${pid}" && result=0 || result=$?

    if [[ ${result} -eq 0 ]] && \
       grep -q 'finish backup' "${tmpout}"; then
        echo "PASS '${FUNCNAME[0]}': end-to-end backup completed"
    else
        echo "FAIL '${FUNCNAME[0]}': backup exited ${result} or did not finish cleanly"
        cat "${tmpout}" >&2
        return 1
    fi
}

# test_staging_cron_fires: start the container in service mode with a
# one-minute schedule, wait for the cron job to fire and complete, then
# verify the success marker is created.  Provides log-tail feedback every
# 10 s because the full cycle takes at least 60 s.
test_staging_cron_fires() {
    _service_available || { _skip "pfSense or AWS not configured"; return 0; }

    local container
    local extra_env=()
    _append_pfsense_args extra_env
    [[ -n "${AWS_S3_BUCKET_NAME:-}" ]] && \
        extra_env+=(-e "AWS_S3_BUCKET_NAME=${AWS_S3_BUCKET_NAME}")
    [[ -n "${AWS_CONFIG_FILE:-}" ]] && [[ -r "${AWS_CONFIG_FILE}" ]] && \
        extra_env+=(-e "AWS_CONFIG_FILE=${AWS_CONFIG_FILE}" \
                    -v "${AWS_CONFIG_FILE}:${AWS_CONFIG_FILE}:ro")
    [[ -n "${AWS_ACCESS_KEY_ID:-}" ]] && \
        extra_env+=(-e "AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}" \
                    -e "AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY:-}" \
                    -e "AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-}")
    [[ -n "${AWS_DRYRUN:-}" ]] && \
        extra_env+=(-e "AWS_DRYRUN=${AWS_DRYRUN}")

    container=$(docker run --detach \
        -e "CRON_EXPRESSION=* * * * *" \
        "${extra_env[@]}" \
        "${IMAGE}")
    # shellcheck disable=SC2064
    trap "docker rm --force '${container}' >/dev/null 2>&1 || true" RETURN

    local elapsed=0 interval=10 timeout=240
    while true; do
        sleep "${interval}"
        elapsed=$(( elapsed + interval ))
        local last_line
        last_line=$(docker logs "${container}" 2>&1 | tail -1)
        printf '[%ds] last log: %s\n' "${elapsed}" "${last_line}"

        if docker logs "${container}" 2>&1 | grep -q 'finish backup'; then
            echo "PASS '${FUNCNAME[0]}': cron job fired and backup completed"
            return 0
        fi

        if (( elapsed >= timeout )); then
            echo "FAIL '${FUNCNAME[0]}': timed out after ${timeout}s waiting for cron backup"
            docker logs "${container}" 2>&1 | tail -30 >&2
            return 1
        fi
    done
}

# ---------------------------------------------------------------------------
# Setup
# ---------------------------------------------------------------------------

setup() {
    [[ -n "${IMAGE}" ]] || {
        echo "ERROR: IMAGE is not set" >&2
        echo "       Pass it as a positional arg or use --image IMAGE" >&2
        return 1
    }
    if ! docker image inspect "${IMAGE}" >/dev/null 2>&1; then
        echo "ERROR: image '${IMAGE}' not found in local Docker daemon" >&2
        echo "       Build it first with: ./build" >&2
        return 1
    fi
    if ! docker run --rm --entrypoint /bin/sh \
           "${IMAGE}" -c 'test -x /usr/local/bin/backup' 2>/dev/null; then
        echo "ERROR: /usr/local/bin/backup missing or not executable in '${IMAGE}'" >&2
        return 1
    fi
}

# ---------------------------------------------------------------------------
# Test runner
# ---------------------------------------------------------------------------

run_tests() {
    local all_tests=(
        test_staging_image_has_backup
        test_staging_image_has_pfsense_backup
        test_staging_image_has_startup
        test_staging_image_has_healthcheck
        test_staging_image_has_sshpass
        test_staging_image_has_ssh
        test_staging_image_has_aws
        test_staging_missing_bucket_exits_nonzero
        test_staging_missing_host_exits_nonzero
        test_staging_missing_identity_file_exits_nonzero
        test_staging_missing_password_exits_nonzero
        test_staging_backup_downloads_config
        test_staging_backup_xml_has_expected_fields
        test_staging_backup_direct
        test_staging_cron_fires
    )

    # Apply --test filter.
    local tests=()
    if [[ -n "${_ONLY_TEST}" ]]; then
        local valid=false t
        for t in "${all_tests[@]}"; do
            [[ "${t}" == "${_ONLY_TEST}" ]] && valid=true && break
        done
        if ! "${valid}"; then
            echo "ERROR: unknown test '${_ONLY_TEST}'" >&2
            printf '       Available tests:\n' >&2
            printf '         %s\n' "${all_tests[@]}" >&2
            return 1
        fi
        tests=("${_ONLY_TEST}")
    else
        tests=("${all_tests[@]}")
    fi

    setup || { echo "ERROR: setup failed"; return 1; }

    echo "Running staging tests for pfsense-backup..."
    echo "============================================="
    echo "Image:   ${IMAGE}"
    if _pfsense_available; then
        echo "pfSense: ${PFSENSE_HOST}"
    else
        echo "pfSense: not configured — pfSense-dependent tests will be skipped"
    fi
    if _aws_available; then
        echo "Bucket:  ${AWS_S3_BUCKET_NAME}"
        echo "Dryrun:  ${AWS_DRYRUN:-auto}"
    else
        echo "AWS:     not configured — AWS-dependent tests will be skipped"
    fi
    echo "Scans:   Trivy=${_SCAN} Grype=${_ADVISE_GRYPE} Scout=${_ADVISE_SCOUT} Dive=${_ADVISE_DIVE}"
    [[ -n "${_ONLY_TEST}" ]] && echo "Filter:  --test ${_ONLY_TEST}"
    echo "============================================="

    if [[ "${_SCAN}" == "true" ]]; then
        echo "==> Scan: Trivy ${IMAGE}" >&2
        _trivy_tar=$(mktemp /tmp/trivy-scan-XXXXXX.tar)
        trap 'rm -f "${_trivy_tar}"' EXIT
        docker image save "${IMAGE}" -o "${_trivy_tar}"
        docker run --rm \
            -v "${_trivy_tar}:/scan.tar:ro" \
            -v "${TRIVY_CACHE_VOLUME}:/root/.cache/trivy" \
            "${TRIVY_IMAGE}:${TRIVY_TAG}" image \
                --exit-code 1 \
                --ignore-unfixed \
                --severity HIGH,CRITICAL \
                --input /scan.tar
        rm -f "${_trivy_tar}"
        trap - EXIT
    fi

    if [[ "${_ADVISE_GRYPE}" == "true" ]]; then
        echo "==> Advise: Grype ${IMAGE}" >&2
        _grype_tar=$(mktemp /tmp/grype-scan-XXXXXX.tar)
        trap 'rm -f "${_grype_tar}"' EXIT
        docker image save "${IMAGE}" -o "${_grype_tar}"
        docker run --rm \
            -v "${_grype_tar}:/scan.tar:ro" \
            -v "${GRYPE_CACHE_VOLUME}:/root/.cache/grype" \
            "${GRYPE_IMAGE}:${GRYPE_TAG}" \
                docker-archive:/scan.tar || true
        rm -f "${_grype_tar}"
        trap - EXIT
    fi

    if [[ "${_ADVISE_SCOUT}" == "true" ]]; then
        echo "==> Advise: Scout ${IMAGE}" >&2
        docker scout cves "${IMAGE}" || true
    fi

    if [[ "${_ADVISE_DIVE}" == "true" ]]; then
        echo "==> Advise: Dive ${IMAGE}" >&2
        _dive_tar=$(mktemp /tmp/dive-scan-XXXXXX.tar)
        trap 'rm -f "${_dive_tar}"' EXIT
        docker save "${IMAGE}" > "${_dive_tar}"
        docker run --rm \
            -v "${_dive_tar}:/scan.tar:ro" \
            "${DIVE_IMAGE}:${DIVE_TAG}" \
                --source docker-archive \
                --ci \
                /scan.tar || true
        rm -f "${_dive_tar}"
        trap - EXIT
    fi

    _SKIP_COUNT=0
    local passed=0 failed=0
    for t in "${tests[@]}"; do
        if "${t}"; then
            (( ++passed )) || true
        else
            (( ++failed )) || true
        fi
    done
    # Subtract skips from passed: skipped tests exit 0 but are not passes.
    passed=$(( passed - _SKIP_COUNT ))

    local total=$(( ${#tests[@]} ))
    echo "============================================="
    echo "Results: ${passed} passed, ${failed} failed," \
         "${_SKIP_COUNT} skipped (${total} run)"
    return "${failed}"
}

# ---------------------------------------------------------------------------
# Main — option parsing, preflight, warning, confirmation, then run tests
# ---------------------------------------------------------------------------

main() {
    # ── Option parsing ────────────────────────────────────────────────────────
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image)                   IMAGE="$2";                       shift ;;
            --host)                    PFSENSE_HOST="$2";                shift ;;
            --identity-file)           PFSENSE_IDENTITY_FILE="$2";      shift ;;
            --identity-password)       PFSENSE_IDENTITY_PASSWORD="$2";  shift ;;
            --identity-password-file)  PFSENSE_IDENTITY_PASSWORD_FILE="$2"; shift ;;
            --compression)             COMPRESSION="$2";                 shift ;;
            --bucket)                  AWS_S3_BUCKET_NAME="$2";          shift ;;
            --aws-config)              AWS_CONFIG_FILE="$2";             shift ;;
            --dryrun)                  AWS_DRYRUN=true  ;;
            --no-dryrun)               AWS_DRYRUN=false ;;
            --scan)                    _SCAN=true ;;
            --no-scan)                 _SCAN=false ;;
            --advise|--advice)
                _ADVISE_EXPLICIT=true
                if [[ $# -gt 1 && ! "$2" =~ ^-- ]]; then
                    advisements="$2"
                    shift
                else
                    advisements="grype,scout"
                fi
                _ADVISE_GRYPE=false
                _ADVISE_SCOUT=false
                _ADVISE_DIVE=false
                IFS=',' read -ra adv_list <<< "$advisements"
                for adv in "${adv_list[@]}"; do
                    case "$adv" in
                        grype)  _ADVISE_GRYPE=true ;;
                        scout)  _ADVISE_SCOUT=true ;;
                        dive)   _ADVISE_DIVE=true ;;
                        all)    _ADVISE_GRYPE=true; _ADVISE_SCOUT=true; _ADVISE_DIVE=true ;;
                        *)      echo "Unknown advisement: $adv" >&2; exit 1 ;;
                    esac
                done
                ;;
            --no-advise)
                _ADVISE_EXPLICIT=true
                _ADVISE_GRYPE=false
                _ADVISE_SCOUT=false
                _ADVISE_DIVE=false
                ;;
            --yes)                     _YES=true ;;
            --test)                    _ONLY_TEST="$2"; shift ;;
            -h|--help)    show_help; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                echo "Run 'test/staging --help' for usage." >&2
                exit 1 ;;
            *)
                # First non-option positional arg is the image.
                if [[ -z "${IMAGE}" ]]; then
                    IMAGE="$1"
                else
                    echo "Unexpected argument: $1" >&2
                    exit 1
                fi ;;
        esac
        shift
    done

    if [[ "${_SCAN}" == "false" && "${_ADVISE_EXPLICIT}" == "false" ]]; then
        _ADVISE_GRYPE=false
        _ADVISE_SCOUT=false
        _ADVISE_DIVE=false
    fi

    export IMAGE
    export PFSENSE_HOST PFSENSE_IDENTITY_FILE PFSENSE_IDENTITY_PASSWORD \
           PFSENSE_IDENTITY_PASSWORD_FILE COMPRESSION
    export AWS_S3_BUCKET_NAME AWS_CONFIG_FILE AWS_DRYRUN _YES _ONLY_TEST
    export _SCAN _ADVISE_GRYPE _ADVISE_SCOUT _ADVISE_DIVE _ADVISE_EXPLICIT

    local bucket="${AWS_S3_BUCKET_NAME:-}"
    local pw_file="${PFSENSE_IDENTITY_PASSWORD_FILE:-/run/secrets/pfsense-identity-password}"

    local will_touch_pfsense=false will_touch_aws=false
    [[ -n "${PFSENSE_HOST:-}" ]] && \
        [[ -n "${PFSENSE_IDENTITY_FILE:-}" ]] && \
        { [[ -n "${PFSENSE_IDENTITY_PASSWORD:-}" ]] || [[ -r "${pw_file}" ]]; } && \
        will_touch_pfsense=true
    [[ -n "${bucket}" ]] && \
        { [[ -r "${AWS_CONFIG_FILE:-}" ]] || [[ -n "${AWS_ACCESS_KEY_ID:-}" ]]; } && \
        will_touch_aws=true

    # Bucket safety: force AWS_DRYRUN=true for non-test/staging buckets unless
    # the caller has explicitly set AWS_DRYRUN=false.
    local caution_bucket=false
    if [[ -n "${bucket}" ]] && \
       [[ "${bucket}" != test.* ]] && \
       [[ "${bucket}" != staging.* ]]; then
        caution_bucket=true
        if [[ "${AWS_DRYRUN:-}" != "false" ]]; then
            AWS_DRYRUN=true
            export AWS_DRYRUN
        fi
    fi

    # Detect common mistake: PFSENSE_IDENTITY_PASSWORD set to a file path.
    # When the value is a readable local path the credential blocks below
    # will bind-mount it and forward it as PFSENSE_IDENTITY_PASSWORD_FILE.
    if [[ -n "${PFSENSE_IDENTITY_PASSWORD:-}" ]] && \
       [[ -r "${PFSENSE_IDENTITY_PASSWORD}" ]]; then
        echo ""
        echo "  NOTE: PFSENSE_IDENTITY_PASSWORD='${PFSENSE_IDENTITY_PASSWORD}'"
        echo "  is a readable file — treating it as PFSENSE_IDENTITY_PASSWORD_FILE"
        echo "  and bind-mounting it into the container."
        echo "  Use PFSENSE_IDENTITY_PASSWORD_FILE to suppress this note."
    fi

    echo ""
    echo "================================================================"
    echo "  WARNING: pfsense-backup staging tests"
    echo "================================================================"
    echo ""
    echo "  Image: ${IMAGE:-<not set>}"
    echo ""
    echo "  These tests exercise LIVE systems."
    echo ""
    if "${will_touch_pfsense}"; then
        echo "  pfSense host : ${PFSENSE_HOST}"
    fi
    if "${will_touch_aws}"; then
        echo "  S3 bucket    : ${bucket}"
        if [[ "${AWS_DRYRUN:-false}" == "true" ]]; then
            echo "  AWS mode     : DRY RUN (no real S3 writes)"
        else
            echo "  AWS mode     : LIVE (real S3 writes)"
        fi
    else
        echo "  AWS:           not configured — AWS-dependent tests will be skipped"
    fi
    echo ""

    if "${caution_bucket}"; then
        echo "  !! CAUTION !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
        echo "  !! BUCKET='${bucket}'"
        echo "  !! does not start with 'test.' or 'staging.'."
        if [[ "${AWS_DRYRUN:-}" == "false" ]]; then
            echo "  !! --no-dryrun: real objects WILL be written to S3."
        else
            echo "  !! AWS_DRYRUN forced to 'true' for safety."
            echo "  !! Pass --no-dryrun to allow real S3 writes."
        fi
        echo "  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
        echo ""
    fi

    # ── Confirmation ──────────────────────────────────────────────────────────
    # Prompt only when real systems will be touched; --yes skips for scripted use.
    if "${will_touch_pfsense}" || "${will_touch_aws}"; then
        if "${_YES}"; then
            echo "  (--yes: skipping confirmation prompt)"
            echo ""
        else
            printf 'Type "yes" to proceed, or press Enter to abort: '
            local response
            read -r response
            echo ""
            if [[ "${response}" != "yes" ]]; then
                echo "Aborted."
                return 1
            fi
        fi
    fi

    run_tests
}

[[ "${BASH_SOURCE[0]}" == "$0" ]] && main "$@"
