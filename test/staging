run_tests() {
    local all_tests=(
        test_staging_image_has_backup
        test_staging_image_has_pfsense_backup
        test_staging_image_has_startup
        test_staging_image_has_healthcheck
        test_staging_image_has_sshpass
        test_staging_image_has_ssh
        test_staging_image_has_aws
        test_staging_missing_bucket_exits_nonzero
        test_staging_missing_host_exits_nonzero
        test_staging_missing_identity_file_exits_nonzero
        test_staging_missing_password_exits_nonzero
        test_staging_healthcheck_healthy
        test_staging_healthcheck_unhealthy_no_crontab
        test_staging_healthcheck_unhealthy_no_supercronic
        test_staging_healthcheck_healthy_grace_period
        test_staging_healthcheck_unhealthy_stale_backup
        test_staging_cron_startup
        test_staging_backup_downloads_config
        test_staging_backup_xml_has_expected_fields
        test_staging_backup_direct
        test_staging_cron_fires
        test_staging_trivy_scan
        test_staging_grype_advise
        test_staging_scout_advise
        test_staging_dive_advise
        test_staging_coverage_advise
    )

    # Apply --test filter.
    local tests=()
    if [[ -n "${_ONLY_TEST}" ]]; then
        local valid=false t
        for t in "${all_tests[@]}"; do
            [[ "${t}" == "${_ONLY_TEST}" ]] && valid=true && break
        done
        if ! "${valid}"; then
            echo "ERROR: unknown test '${_ONLY_TEST}'" >&2
            printf '       Available tests:\n' >&2
            printf '         %s\n' "${all_tests[@]}" >&2
            return 1
        fi
        tests=("${_ONLY_TEST}")
    else
        tests=("${all_tests[@]}")
    fi

    setup || { echo "ERROR: setup failed"; return 1; }

    if [[ "${_CACHE_RESET_TRIVY}" == "true" ]]; then
        echo "==> Cache: reset Trivy DB" >&2
        _reset_cache_db "${TRIVY_CACHE_VOLUME}"
    fi
    if [[ "${_CACHE_RESET_GRYPE}" == "true" ]]; then
        echo "==> Cache: reset Grype DB" >&2
        _reset_cache_db "${GRYPE_CACHE_VOLUME}"
    fi

    echo "Running staging tests for pfsense-backup..."
    echo "============================================="
    echo "Image:   ${IMAGE}"
    if _pfsense_available; then
        echo "pfSense: ${PFSENSE_HOST}"
    else
        echo "pfSense: not configured — pfSense-dependent tests will be skipped"
    fi
    if _aws_available; then
        echo "Bucket:  ${AWS_S3_BUCKET_NAME}"
        echo "Dryrun:  ${AWS_DRYRUN:-auto}"
    else
        echo "AWS:     not configured — AWS-dependent tests will be skipped"
    fi
    echo "Scan:    ${_SCAN} (Trivy HIGH/CRITICAL)"
    echo "Advise:  coverage=${_ADVISE_COVERAGE} dive=${_ADVISE_DIVE}" \
         "grype=${_ADVISE_GRYPE} scout=${_ADVISE_SCOUT}"
    [[ -n "${_ONLY_TEST}" ]] && echo "Filter:  --test ${_ONLY_TEST}"
    echo "============================================="

    _SKIP_COUNT=0
    local passed=0 failed=0
    for t in "${tests[@]}"; do
        if "${t}"; then
            (( ++passed )) || true
        else
            (( ++failed )) || true
        fi
    done
    # Subtract skips from passed: skipped tests exit 0 but are not passes.
    passed=$(( passed - _SKIP_COUNT ))

    local total=$(( ${#tests[@]} ))
    echo "============================================="
    echo "Results: ${passed} passed, ${failed} failed," \
         "${_SKIP_COUNT} skipped (${total} run)"
    return "${failed}"
}

# ---------------------------------------------------------------------------
# Main — option parsing, preflight, warning, confirmation, then run tests
# ---------------------------------------------------------------------------

main() {
    # ── Option parsing ────────────────────────────────────────────────────────
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image)                   IMAGE="$2";                       shift ;;
            --host)                    PFSENSE_HOST="$2";                shift ;;
            --user)                    PFSENSE_USER="$2";                shift ;;
            --identity-file)           PFSENSE_IDENTITY_FILE="$2";      shift ;;
            --identity-password)       PFSENSE_IDENTITY_PASSWORD="$2";  shift ;;
            --identity-password-file)  PFSENSE_IDENTITY_PASSWORD_FILE="$2"; shift ;;
            --compression)             COMPRESSION="$2";                 shift ;;
            --bucket)                  AWS_S3_BUCKET_NAME="$2";          shift ;;
            --aws-config)              AWS_CONFIG_FILE="$2";             shift ;;
            --aws-credentials)         AWS_CREDENTIALS_FILE="$2";       shift ;;
            --dryrun)                  AWS_DRYRUN=true  ;;
            --no-dryrun)               AWS_DRYRUN=false ;;
            --scan)                    _SCAN=true ;;
            --no-scan)                 _SCAN=false ;;
            --no-coverage)             _ADVISE_COVERAGE=false ;;
            --advise|--advice)
                _ADVISE_EXPLICIT=true
                # Accept an optional advisement list only when the next arg
                # looks like one (not an image name or another flag).
                if [[ $# -gt 1 && "$2" =~ \
                        ^(coverage|dive|grype|scout|all)(,(coverage|dive|grype|scout|all))*$ ]]; then
                    advisements="$2"; shift
                else
                    advisements="all"
                fi
                _ADVISE_COVERAGE=false
                _ADVISE_DIVE=false
                _ADVISE_GRYPE=false
                _ADVISE_SCOUT=false
                IFS=',' read -ra adv_list <<< "$advisements"
                for adv in "${adv_list[@]}"; do
                    case "$adv" in
                        coverage) _ADVISE_COVERAGE=true ;;
                        dive)     _ADVISE_DIVE=true ;;
                        grype)    _ADVISE_GRYPE=true ;;
                        scout)    _ADVISE_SCOUT=true ;;
                        all) _ADVISE_COVERAGE=true; _ADVISE_DIVE=true
                             _ADVISE_GRYPE=true; _ADVISE_SCOUT=true ;;
                        *)   echo "Unknown advisement: $adv" >&2; exit 1 ;;
                    esac
                done
                ;;
            --no-advise)
                _ADVISE_EXPLICIT=true
                _ADVISE_COVERAGE=false
                _ADVISE_DIVE=false
                _ADVISE_GRYPE=false
                _ADVISE_SCOUT=false
                ;;
            --cache)
                [[ $# -ge 2 ]] || {
                    echo "option '${1}' requires an argument" >&2; exit 1; }
                _parse_cache_rules "$2"; shift
                ;;
            --yes)                     _YES=true ;;
            --test)                    _ONLY_TEST="$2"; shift ;;
            -h|--help)    show_help; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                echo "Run 'test/staging --help' for usage." >&2
                exit 1 ;;
            *)
                # First non-option positional arg is the image.
                if [[ -z "${IMAGE}" ]]; then
                    IMAGE="$1"
                else
                    echo "Unexpected argument: $1" >&2
                    exit 1
                fi ;;
        esac
        shift
    done

    # Expand tilde (~) in file paths.
    [[ "${PFSENSE_IDENTITY_FILE}" == ~* ]] && PFSENSE_IDENTITY_FILE="${PFSENSE_IDENTITY_FILE/#~/$HOME}"
    [[ "${PFSENSE_IDENTITY_PASSWORD_FILE}" == ~* ]] && PFSENSE_IDENTITY_PASSWORD_FILE="${PFSENSE_IDENTITY_PASSWORD_FILE/#~/$HOME}"
    [[ "${PFSENSE_IDENTITY_PASSWORD}" == ~* ]] && PFSENSE_IDENTITY_PASSWORD="${PFSENSE_IDENTITY_PASSWORD/#~/$HOME}"
    [[ "${AWS_CONFIG_FILE}" == ~* ]] && AWS_CONFIG_FILE="${AWS_CONFIG_FILE/#~/$HOME}"
    [[ "${AWS_CREDENTIALS_FILE}" == ~* ]] && AWS_CREDENTIALS_FILE="${AWS_CREDENTIALS_FILE/#~/$HOME}"

    # --no-scan implies --no-advise unless --advise was given explicitly.
    if [[ "${_SCAN}" == "false" && "${_ADVISE_EXPLICIT}" == "false" ]]; then
        _ADVISE_COVERAGE=false
        _ADVISE_DIVE=false
        _ADVISE_GRYPE=false
        _ADVISE_SCOUT=false
    fi

    export IMAGE
    export PFSENSE_HOST PFSENSE_IDENTITY_FILE PFSENSE_IDENTITY_PASSWORD \
           PFSENSE_IDENTITY_PASSWORD_FILE COMPRESSION
    export AWS_S3_BUCKET_NAME AWS_CONFIG_FILE AWS_CREDENTIALS_FILE AWS_DRYRUN
    export _YES _ONLY_TEST
    export _SCAN _ADVISE_COVERAGE _ADVISE_DIVE _ADVISE_GRYPE _ADVISE_SCOUT \
           _ADVISE_EXPLICIT
    export _CACHE_RESET_TRIVY _CACHE_RESET_GRYPE
    export _CACHE_SKIP_UPDATE_TRIVY _CACHE_SKIP_UPDATE_GRYPE

    local bucket="${AWS_S3_BUCKET_NAME:-}"
    local pw_file="${PFSENSE_IDENTITY_PASSWORD_FILE:-/run/secrets/pfsense-identity-password}"

    local will_touch_pfsense=false will_touch_aws=false
    [[ -n "${PFSENSE_HOST:-}" ]] && \
        [[ -n "${PFSENSE_IDENTITY_FILE:-}" ]] && \
        { [[ -n "${PFSENSE_IDENTITY_PASSWORD:-}" ]] || [[ -r "${pw_file}" ]]; } && \
        will_touch_pfsense=true
    [[ -n "${bucket}" ]] && \
        { [[ -r "${AWS_CONFIG_FILE:-}" ]] || \
          [[ -r "${AWS_CREDENTIALS_FILE:-}" ]] || \
          [[ -n "${AWS_ACCESS_KEY_ID:-}" ]]; } && \
        will_touch_aws=true

    # Bucket safety: force AWS_DRYRUN=true for non-test/staging buckets unless
    # the caller has explicitly set AWS_DRYRUN=false.
    local caution_bucket=false
    if [[ -n "${bucket}" ]] && \
       [[ "${bucket}" != test.* ]] && \
       [[ "${bucket}" != staging.* ]]; then
        caution_bucket=true
        if [[ "${AWS_DRYRUN:-}" != "false" ]]; then
            AWS_DRYRUN=true
            export AWS_DRYRUN
        fi
    fi

    # Detect common mistake: PFSENSE_IDENTITY_PASSWORD set to a file path.
    # When the value is a readable local path the credential blocks below
    # will bind-mount it and forward it as PFSENSE_IDENTITY_PASSWORD_FILE.
    if [[ -n "${PFSENSE_IDENTITY_PASSWORD:-}" ]] && \
       [[ -r "${PFSENSE_IDENTITY_PASSWORD}" ]]; then
        echo ""
        echo "  NOTE: PFSENSE_IDENTITY_PASSWORD='${PFSENSE_IDENTITY_PASSWORD}'"
        echo "  is a readable file — treating it as PFSENSE_IDENTITY_PASSWORD_FILE"
        echo "  and bind-mounting it into the container."
        echo "  Use PFSENSE_IDENTITY_PASSWORD_FILE to suppress this note."
    fi

    local _advise_any=false
    [[ "${_ADVISE_COVERAGE}" == "true" || "${_ADVISE_DIVE}" == "true" \
        || "${_ADVISE_GRYPE}" == "true" || "${_ADVISE_SCOUT}" == "true" ]] \
        && _advise_any=true

    echo ""
    echo "================================================================"
    echo "  WARNING: pfsense-backup staging tests"
    echo "================================================================"
    echo ""
    echo "  Image: ${IMAGE:-<not set>}"
    echo ""
    if [[ "${_SCAN}" == "true" ]]; then
        echo "  Scan:     Trivy HIGH/CRITICAL (--no-scan to skip)"
    else
        echo "  Scan:     skipped (--no-scan)"
    fi
    if "${_advise_any}"; then
        local _advise_list=()
        [[ "${_ADVISE_COVERAGE}" == "true" ]] && _advise_list+=(coverage)
        [[ "${_ADVISE_DIVE}"     == "true" ]] && _advise_list+=(dive)
        [[ "${_ADVISE_GRYPE}"    == "true" ]] && _advise_list+=(grype)
        [[ "${_ADVISE_SCOUT}"    == "true" ]] && _advise_list+=(scout)
        local IFS=,
        echo "  Advise:   ${_advise_list[*]} (--no-advise to skip)"
    elif [[ "${_SCAN}" == "false" && "${_ADVISE_EXPLICIT}" == "false" ]]; then
        echo "  Advise:   skipped (implied by --no-scan; use --advise to enable)"
    else
        echo "  Advise:   skipped (--no-advise)"
    fi
    echo ""
    echo "  These tests exercise LIVE systems."
    echo ""
    if "${will_touch_pfsense}"; then
        echo "  pfSense host : ${PFSENSE_HOST}"
    fi
    if "${will_touch_aws}"; then
        echo "  S3 bucket    : ${bucket}"
        if [[ "${AWS_DRYRUN:-false}" == "true" ]]; then
            echo "  AWS mode     : DRY RUN (no real S3 writes)"
        else
            echo "  AWS mode     : LIVE (real S3 writes)"
        fi
    else
        echo "  AWS:           not configured — AWS-dependent tests will be skipped"
    fi
    echo ""

    if "${caution_bucket}"; then
        echo "  !! CAUTION !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
        echo "  !! BUCKET='${bucket}'"
        echo "  !! does not start with 'test.' or 'staging.'."
        if [[ "${AWS_DRYRUN:-}" == "false" ]]; then
            echo "  !! --no-dryrun: real objects WILL be written to S3."
        else
            echo "  !! AWS_DRYRUN forced to 'true' for safety."
            echo "  !! Pass --no-dryrun to allow real S3 writes."
        fi
        echo "  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
        echo ""
    fi

    # ── Confirmation ──────────────────────────────────────────────────────────
    # Prompt only when real systems will be touched; --yes skips for scripted use.
    if "${will_touch_pfsense}" || "${will_touch_aws}"; then
        if "${_YES}"; then
            echo "  (--yes: skipping confirmation prompt)"
            echo ""
        else
            printf 'Type "yes" to proceed, or press Enter to abort: '
            local response
            read -r response
            echo ""
            if [[ "${response}" != "yes" ]]; then
                echo "Aborted."
                return 1
            fi
        fi
    fi

    run_tests
}

[[ "${BASH_SOURCE[0]}" == "$0" ]] && main "$@"
