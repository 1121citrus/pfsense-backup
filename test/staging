# test_staging_backup_direct: run backup end-to-end with real pfSense + AWS.
# Provides progress feedback every 10 s because the SSH + upload may take
# 30–90 s on a slow connection.
test_staging_backup_direct() {
    _service_available || { _skip "pfSense or AWS not configured"; return 0; }

    local tmpout
    tmpout=$(mktemp)
    # shellcheck disable=SC2064
    trap "rm -f '${tmpout}'" RETURN

    run_backup >"${tmpout}" 2>&1 &
    local pid=$!

    local elapsed=0 interval=10 timeout=300
    while kill -0 "${pid}" 2>/dev/null; do
        sleep "${interval}"
        elapsed=$(( elapsed + interval ))
        printf '[%ds] backup in progress...\n' "${elapsed}"
        if (( elapsed >= timeout )); then
            kill "${pid}" 2>/dev/null || true
            echo "FAIL '${FUNCNAME[0]}': timed out after ${timeout}s"
            cat "${tmpout}" >&2
            return 1
        fi
    done
    local result
    wait "${pid}" && result=0 || result=$?

    if [[ ${result} -eq 0 ]] && \
       grep -q 'finish backup' "${tmpout}"; then
        echo "PASS '${FUNCNAME[0]}': end-to-end backup completed"
    else
        echo "FAIL '${FUNCNAME[0]}': backup exited ${result} or did not finish cleanly"
        cat "${tmpout}" >&2
        return 1
    fi
}

# test_staging_cron_startup: verify the scheduler container starts, writes its
# crontab, and stays running — no pfSense host or AWS credentials required.
# Catches Dockerfile permission regressions (e.g. /var/spool/cron/crontabs
# root-owned via Alpine symlink) that CLI-mode tests cannot exercise.
test_staging_cron_startup() {
    local container_id
    # Use @daily so the job never fires during the test window.
    # shellcheck disable=SC2086
    container_id=$(docker run --detach \
        -e "BUCKET=test.fake-bucket-for-startup-test" \
        -e "CRON_EXPRESSION=@daily" \
        ${DOCKER_RUN_ARGS:-} \
        "${IMAGE}")
    printf '  container %s started; waiting for scheduler init...\n' \
        "${container_id:0:12}" >&2

    sleep 3

    local running
    running=$(docker inspect --format '{{.State.Running}}' "${container_id}" \
        2>/dev/null || echo "false")

    local crontab_ok=false
    if [[ "${running}" == "true" ]]; then
        docker exec "${container_id}" \
            test -f /var/spool/cron/crontabs/pfsense-backup \
            > /dev/null 2>&1 && crontab_ok=true
    fi

    docker stop "${container_id}" > /dev/null 2>&1
    docker rm   "${container_id}" > /dev/null 2>&1

    if [[ "${running}" != "true" ]]; then
        echo "FAIL '${FUNCNAME[0]}': container exited within 3s of startup"
        return 1
    fi
    if ! "${crontab_ok}"; then
        echo "FAIL '${FUNCNAME[0]}': crontab file not found" \
             "(crontabs directory likely root-owned)"
        return 1
    fi
    echo "PASS '${FUNCNAME[0]}': scheduler running and crontab written"
}

# test_staging_cron_fires: start the container in service mode with a
# one-minute schedule, wait for the cron job to fire and complete, then
# verify the success marker is created.  Provides log-tail feedback every
# 10 s because the full cycle takes at least 60 s.
test_staging_cron_fires() {
    _service_available || { _skip "pfSense or AWS not configured"; return 0; }

    local container
    local extra_env=()
    _append_pfsense_args extra_env
    [[ -n "${AWS_S3_BUCKET_NAME:-}" ]] && \
        extra_env+=(-e "AWS_S3_BUCKET_NAME=${AWS_S3_BUCKET_NAME}")
    if [[ -r "${_aws_cfg_mount:-/nonexistent}" ]]; then
        extra_env+=(-e "AWS_CONFIG_FILE=/run/secrets/aws-config" \
                    -v "${_aws_cfg_mount}:/run/secrets/aws-config:ro")
    fi
    if [[ -r "${_aws_creds_mount:-/nonexistent}" ]]; then
        extra_env+=(-e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials" \
                    -v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro")
    fi
    [[ -n "${AWS_ACCESS_KEY_ID:-}" ]] && \
        extra_env+=(-e "AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}" \
                    -e "AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY:-}" \
                    -e "AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-}")
    [[ -n "${AWS_DRYRUN:-}" ]] && \
        extra_env+=(-e "AWS_DRYRUN=${AWS_DRYRUN}")

    # shellcheck disable=SC2086
    container=$(docker run --detach \
        -e "CRON_EXPRESSION=* * * * *" \
        -e "AWS_RETRY_MODE=standard" \
        -e "AWS_MAX_ATTEMPTS=5" \
        ${DOCKER_RUN_ARGS:-} \
        "${extra_env[@]}" \
        "${IMAGE}")
    # shellcheck disable=SC2064
    trap "docker rm --force '${container}' >/dev/null 2>&1 || true" RETURN

    local elapsed=0 interval=10 timeout=240
    while true; do
        sleep "${interval}"
        elapsed=$(( elapsed + interval ))
        local last_line
        last_line=$(docker logs "${container}" 2>&1 | tail -1)
        printf '[%ds] last log: %s\n' "${elapsed}" "${last_line}"

        if docker logs "${container}" 2>&1 | grep -q 'finish backup'; then
            echo "PASS '${FUNCNAME[0]}': cron job fired and backup completed"
            return 0
        fi

        if (( elapsed >= timeout )); then
            echo "FAIL '${FUNCNAME[0]}': timed out after ${timeout}s waiting for cron backup"
            docker logs "${container}" 2>&1 | tail -30 >&2
            return 1
        fi
    done
}

