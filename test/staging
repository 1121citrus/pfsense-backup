# ---------------------------------------------------------------------------
# Tests — pfSense-dependent (require a live pfSense host)
# ---------------------------------------------------------------------------

test_staging_backup_downloads_config() {
    if ! _pfsense_available; then
        echo "SKIP '${FUNCNAME[0]}': PFSENSE_HOST / identity not configured"
        return 0
    fi
    local output result=0
    output=$(run_backup \
        -e AWS_S3_BUCKET_NAME=test-bucket \
        -e AWS_DRYRUN=true \
        2>&1) && result=0 || result=$?
    if [[ ${result} -eq 0 ]] && \
       [[ "${output}" == *'finish backup'* ]]; then
        echo "PASS '${FUNCNAME[0]}': backup completed against live pfSense"
    else
        echo "FAIL '${FUNCNAME[0]}': expected 'finish backup' in output"
        printf '%s\n' "${output}" | tail -20 >&2
        return 1
    fi
}

test_staging_backup_xml_has_expected_fields() {
    if ! _pfsense_available; then
        echo "SKIP '${FUNCNAME[0]}': PFSENSE_HOST / identity not configured"
        return 0
    fi
    local output result=0
    output=$(run_backup \
        -e AWS_S3_BUCKET_NAME=test-bucket \
        -e AWS_DRYRUN=true \
        2>&1) && result=0 || result=$?
    # The backup filename embeds hostname and version — their presence in the
    # log confirms that XML field extraction succeeded.
    if [[ ${result} -eq 0 ]] && \
       [[ "${output}" == *'-pfsense-v'* ]] && \
       [[ "${output}" == *'-config-backup.xml'* ]]; then
        echo "PASS '${FUNCNAME[0]}': backup filename contains hostname and version fields"
    else
        echo "FAIL '${FUNCNAME[0]}': expected hostname/version in backup filename"
        printf '%s\n' "${output}" | tail -20 >&2
        return 1
    fi
}

# ---------------------------------------------------------------------------
# Tests — full pipeline (pfSense + AWS)
# ---------------------------------------------------------------------------

# test_staging_backup_direct: run backup end-to-end with real pfSense + AWS.
# Provides progress feedback every 10 s because the SSH + upload may take
# 30–90 s on a slow connection.
test_staging_backup_direct() {
    if ! _service_available; then
        echo "SKIP '${FUNCNAME[0]}': pfSense or AWS not configured"
        return 0
    fi

    local tmpout
    tmpout=$(mktemp)
    # shellcheck disable=SC2064
    trap "rm -f '${tmpout}'" RETURN

    run_backup >"${tmpout}" 2>&1 &
    local pid=$!

    local elapsed=0 interval=10 timeout=300
    while kill -0 "${pid}" 2>/dev/null; do
        sleep "${interval}"
        elapsed=$(( elapsed + interval ))
        printf '[%ds] backup in progress...\n' "${elapsed}"
        if (( elapsed >= timeout )); then
            kill "${pid}" 2>/dev/null || true
            echo "FAIL '${FUNCNAME[0]}': timed out after ${timeout}s"
            cat "${tmpout}" >&2
            return 1
        fi
    done
    local result
    wait "${pid}" && result=0 || result=$?

    if [[ ${result} -eq 0 ]] && \
       grep -q 'finish backup' "${tmpout}"; then
        echo "PASS '${FUNCNAME[0]}': end-to-end backup completed"
    else
        echo "FAIL '${FUNCNAME[0]}': backup exited ${result} or did not finish cleanly"
        cat "${tmpout}" >&2
        return 1
    fi
}

# test_staging_cron_fires: start the container in service mode with a
# one-minute schedule, wait for the cron job to fire and complete, then
# verify the success marker is created.  Provides log-tail feedback every
# 10 s because the full cycle takes at least 60 s.
test_staging_cron_fires() {
    if ! _service_available; then
        echo "SKIP '${FUNCNAME[0]}': pfSense or AWS not configured"
        return 0
    fi

    local container
    local extra_env=()
    _append_pfsense_args extra_env
    [[ -n "${AWS_S3_BUCKET_NAME:-}" ]] && \
        extra_env+=(-e "AWS_S3_BUCKET_NAME=${AWS_S3_BUCKET_NAME}")
    [[ -n "${AWS_CONFIG_FILE:-}" ]] && [[ -r "${AWS_CONFIG_FILE}" ]] && \
        extra_env+=(-e "AWS_CONFIG_FILE=${AWS_CONFIG_FILE}" \
                    -v "${AWS_CONFIG_FILE}:${AWS_CONFIG_FILE}:ro")
    [[ -n "${AWS_ACCESS_KEY_ID:-}" ]] && \
        extra_env+=(-e "AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}" \
                    -e "AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY:-}" \
                    -e "AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-}")
    [[ -n "${AWS_DRYRUN:-}" ]] && \
        extra_env+=(-e "AWS_DRYRUN=${AWS_DRYRUN}")

    container=$(docker run --detach \
        -e "CRON_EXPRESSION=* * * * *" \
        "${extra_env[@]}" \
        "${IMAGE}")
    # shellcheck disable=SC2064
    trap "docker rm --force '${container}' >/dev/null 2>&1 || true" RETURN

    local elapsed=0 interval=10 timeout=240
    while true; do
        sleep "${interval}"
        elapsed=$(( elapsed + interval ))
        local last_line
        last_line=$(docker logs "${container}" 2>&1 | tail -1)
        printf '[%ds] last log: %s\n' "${elapsed}" "${last_line}"

        if docker logs "${container}" 2>&1 | grep -q 'finish backup'; then
            echo "PASS '${FUNCNAME[0]}': cron job fired and backup completed"
            return 0
        fi

        if (( elapsed >= timeout )); then
            echo "FAIL '${FUNCNAME[0]}': timed out after ${timeout}s waiting for cron backup"
            docker logs "${container}" 2>&1 | tail -30 >&2
            return 1
        fi
    done
}

# ---------------------------------------------------------------------------
# Setup
# ---------------------------------------------------------------------------

setup() {
    # Accept IMAGE as $1 (overrides env var).
    IMAGE="${1:-${IMAGE:-}}"
    if [[ -z "${IMAGE}" ]]; then
        echo "ERROR: IMAGE is required (pass as \$1 or set IMAGE env var)" >&2
        return 1
    fi
    if ! docker image inspect "${IMAGE}" >/dev/null 2>&1; then
        echo "ERROR: image '${IMAGE}' not found in local Docker daemon" >&2
        echo "       Build it first with: ./build" >&2
        return 1
    fi
    if ! docker run --rm --entrypoint /bin/sh \
           "${IMAGE}" -c 'test -x /usr/local/bin/backup' 2>/dev/null; then
        echo "ERROR: /usr/local/bin/backup missing or not executable in '${IMAGE}'" >&2
        return 1
    fi
}

# ---------------------------------------------------------------------------
# Test runner
# ---------------------------------------------------------------------------

run_tests() {
    local -a image_only_tests=(
        test_staging_image_has_backup
        test_staging_image_has_pfsense_backup
        test_staging_image_has_startup
        test_staging_image_has_healthcheck
        test_staging_image_has_sshpass
        test_staging_image_has_ssh
        test_staging_image_has_aws
        test_staging_missing_bucket_exits_nonzero
        test_staging_missing_host_exits_nonzero
        test_staging_missing_identity_file_exits_nonzero
        test_staging_missing_password_exits_nonzero
    )
    local -a live_tests=(
        test_staging_backup_downloads_config
        test_staging_backup_xml_has_expected_fields
        test_staging_backup_direct
        test_staging_cron_fires
    )

    local passed=0 tests=("${image_only_tests[@]}" "${live_tests[@]}")

    setup "${1:-}" || { echo "ERROR: setup failed"; return 1; }

    echo "Running staging tests against image: ${IMAGE}"
    echo "=================================================================="

    for test in "${tests[@]}"; do
        if "${test}"; then (( passed += 1 )) || true; fi
    done

    local failed=$(( ${#tests[@]} - passed ))
    echo "=================================================================="
    echo "Results: ${passed} passed, ${failed} failed"
    return "${failed}"
}

# ---------------------------------------------------------------------------
# Main — preflight, warning, confirmation, then run tests
# ---------------------------------------------------------------------------

main() {
    local image="${1:-${IMAGE:-}}"
    local bucket="${AWS_S3_BUCKET_NAME:-}"
    local pw_file="${PFSENSE_IDENTITY_PASSWORD_FILE:-/run/secrets/pfsense-identity-password}"

    local will_touch_pfsense=false will_touch_aws=false
    [[ -n "${PFSENSE_HOST:-}" ]] && \
        [[ -n "${PFSENSE_IDENTITY_FILE:-}" ]] && \
        { [[ -n "${PFSENSE_IDENTITY_PASSWORD:-}" ]] || [[ -r "${pw_file}" ]]; } && \
        will_touch_pfsense=true
    [[ -n "${bucket}" ]] && \
        { [[ -r "${AWS_CONFIG_FILE:-}" ]] || [[ -n "${AWS_ACCESS_KEY_ID:-}" ]]; } && \
        will_touch_aws=true

    # Bucket safety: force AWS_DRYRUN=true for non-test/staging buckets unless
    # the caller has explicitly set AWS_DRYRUN=false.
    local caution_bucket=false
    if [[ -n "${bucket}" ]] && \
       [[ "${bucket}" != test.* ]] && \
       [[ "${bucket}" != staging.* ]]; then
        caution_bucket=true
        if [[ "${AWS_DRYRUN:-}" != "false" ]]; then
            AWS_DRYRUN=true
            export AWS_DRYRUN
        fi
    fi

    # Detect common mistake: PFSENSE_IDENTITY_PASSWORD set to a file path.
    # When the value is a readable local path the credential blocks below
    # will bind-mount it and forward it as PFSENSE_IDENTITY_PASSWORD_FILE.
    if [[ -n "${PFSENSE_IDENTITY_PASSWORD:-}" ]] && \
       [[ -r "${PFSENSE_IDENTITY_PASSWORD}" ]]; then
        echo ""
        echo "  NOTE: PFSENSE_IDENTITY_PASSWORD='${PFSENSE_IDENTITY_PASSWORD}'"
        echo "  is a readable file — treating it as PFSENSE_IDENTITY_PASSWORD_FILE"
        echo "  and bind-mounting it into the container."
        echo "  Use PFSENSE_IDENTITY_PASSWORD_FILE to suppress this note."
    fi

    echo ""
    echo "========================================================"
    echo "  WARNING: pfsense-backup staging tests"
    echo "========================================================"
    echo ""
    echo "  These tests exercise LIVE systems."
    echo ""
    if "${will_touch_pfsense}"; then
        echo "  pfSense host : ${PFSENSE_HOST}"
    fi
    if "${will_touch_aws}"; then
        echo "  S3 bucket    : ${bucket}"
        if [[ "${AWS_DRYRUN:-false}" == "true" ]]; then
            echo "  AWS mode     : DRY RUN (no real S3 writes)"
        else
            echo "  AWS mode     : LIVE (real S3 writes)"
        fi
    fi
    echo ""

    if "${caution_bucket}"; then
        echo "  !! CAUTION: '${bucket}' does not start with 'test.' or"
        echo "  !! 'staging.' — this is treated as a production bucket."
        if [[ "${AWS_DRYRUN:-}" == "false" ]]; then
            echo "  !! AWS_DRYRUN=false — real objects WILL be written to S3."
        else
            echo "  !! AWS_DRYRUN has been forced to 'true' for safety."
            echo "  !! Set AWS_DRYRUN=false to allow real S3 writes."
        fi
        echo ""
    fi

    if "${will_touch_pfsense}" || "${will_touch_aws}"; then
        printf 'Type "yes" to proceed, or press Enter to abort: '
        local response
        read -r response
        echo ""
        if [[ "${response}" != "yes" ]]; then
            echo "Aborted."
            return 1
        fi
    fi

    run_tests "${image}"
}

[[ "${BASH_SOURCE[0]}" == "$0" ]] && main "$@"
