#!/usr/bin/env bash

# pfsense-backup: test all healthcheck scenarios.
#
# Uses --entrypoint /bin/bash to set up container state before invoking
# /usr/local/bin/healthcheck.
#
# Copyright (C) 2025 James Hanlon [mailto:jim@hanlonsoftware.com]
# SPDX-License-Identifier: AGPL-3.0-or-later

set -euo pipefail

# Shell fragment run inside the container to configure crond and cron table.
CROND_START='crond -l 2 & sleep 0.5'
CRONTAB_SETUP='mkdir -p /var/spool/cron/crontabs && printf "%s\n" "* * * * * /usr/local/bin/backup 2>&1" > /var/spool/cron/crontabs/root'

setup() {
    IMAGE=${IMAGE:-1121citrus/pfsense-backup:latest}

    run_healthcheck() {
        # $1: shell -c script to run inside the container
        # remaining args: extra docker run flags
        local script=$1; shift
        # shellcheck disable=SC2086  # DOCKER_RUN_ARGS is intentionally word-split
        docker run -i --rm ${DOCKER_RUN_ARGS:-} \
            --entrypoint /bin/bash \
            "$@" \
            "${IMAGE}" \
            -c "${script}" >/dev/null 2>&1
    }
    export -f run_healthcheck
}

test_healthcheck_healthy() {
    run_healthcheck \
        "${CROND_START} && ${CRONTAB_SETUP} && touch /tmp/hc-success && /usr/local/bin/healthcheck" \
        -e HEALTHCHECK_SUCCESS_FILE=/tmp/hc-success \
        -e HEALTHCHECK_MAX_AGE_SECONDS=300 \
        -e HEALTHCHECK_STARTUP_GRACE_SECONDS=300 \
        && result=0 || result=$?
    if [[ ${result} -eq 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits 0 when crond running, crontab set, and fresh backup marker present"
    else
        echo "FAIL '${FUNCNAME[0]}': expected exit 0 for fully healthy container"
        return 1
    fi
}

test_healthcheck_no_crontab() {
    run_healthcheck \
        "${CROND_START} && touch /tmp/hc-success && /usr/local/bin/healthcheck" \
        -e HEALTHCHECK_SUCCESS_FILE=/tmp/hc-success \
        -e HEALTHCHECK_MAX_AGE_SECONDS=300 \
        && result=0 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero when crontab is not configured"
    else
        echo "FAIL '${FUNCNAME[0]}': expected non-zero exit when crontab is missing"
        return 1
    fi
}

test_healthcheck_crond_down() {
    run_healthcheck \
        "${CRONTAB_SETUP} && touch /tmp/hc-success && /usr/local/bin/healthcheck" \
        -e HEALTHCHECK_SUCCESS_FILE=/tmp/hc-success \
        -e HEALTHCHECK_MAX_AGE_SECONDS=300 \
        && result=0 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero when crond is not running"
    else
        echo "FAIL '${FUNCNAME[0]}': expected non-zero exit when crond is down"
        return 1
    fi
}

test_healthcheck_stale_backup() {
    run_healthcheck \
        "${CROND_START} && ${CRONTAB_SETUP} && touch /tmp/hc-success && /usr/local/bin/healthcheck" \
        -e HEALTHCHECK_SUCCESS_FILE=/tmp/hc-success \
        -e HEALTHCHECK_MAX_AGE_SECONDS=-1 \
        -e HEALTHCHECK_STARTUP_GRACE_SECONDS=-1 \
        && result=0 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero when backup marker exists but exceeds MAX_AGE_SECONDS"
    else
        echo "FAIL '${FUNCNAME[0]}': expected non-zero exit for stale backup marker"
        return 1
    fi
}

test_healthcheck_within_startup_grace() {
    run_healthcheck \
        "${CROND_START} && ${CRONTAB_SETUP} && touch /tmp/hc-started && /usr/local/bin/healthcheck" \
        -e HEALTHCHECK_SUCCESS_FILE=/tmp/hc-success-absent \
        -e HEALTHCHECK_STARTUP_FILE=/tmp/hc-started \
        -e HEALTHCHECK_MAX_AGE_SECONDS=300 \
        -e HEALTHCHECK_STARTUP_GRACE_SECONDS=300 \
        && result=0 || result=$?
    if [[ ${result} -eq 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits 0 when no backup marker yet but within startup grace period"
    else
        echo "FAIL '${FUNCNAME[0]}': expected exit 0 within startup grace period"
        return 1
    fi
}

test_healthcheck_startup_grace_expired() {
    run_healthcheck \
        "${CROND_START} && ${CRONTAB_SETUP} && touch /tmp/hc-started && /usr/local/bin/healthcheck" \
        -e HEALTHCHECK_SUCCESS_FILE=/tmp/hc-success-absent \
        -e HEALTHCHECK_STARTUP_FILE=/tmp/hc-started \
        -e HEALTHCHECK_STARTUP_GRACE_SECONDS=-1 \
        && result=0 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero when startup grace has expired and no backup ran"
    else
        echo "FAIL '${FUNCNAME[0]}': expected non-zero exit when startup grace is expired"
        return 1
    fi
}

test_healthcheck_stale_backup_within_startup_grace() {
    # Regression test for the healthcheck race condition fix.
    #
    # Simulates a container restart scenario: a stale success marker exists
    # (e.g. from a previous container run on a persistent volume) BUT the
    # startup file is fresh and we are still within the grace window.
    # The healthcheck must return healthy (exit 0) in this case — the old
    # code errored immediately on the stale marker without ever checking grace.
    run_healthcheck \
        "${CROND_START} && ${CRONTAB_SETUP} && touch /tmp/hc-stale-success && touch /tmp/hc-started && /usr/local/bin/healthcheck" \
        -e HEALTHCHECK_SUCCESS_FILE=/tmp/hc-stale-success \
        -e HEALTHCHECK_STARTUP_FILE=/tmp/hc-started \
        -e HEALTHCHECK_MAX_AGE_SECONDS=-1 \
        -e HEALTHCHECK_STARTUP_GRACE_SECONDS=300 \
        && result=0 || result=$?
    if [[ ${result} -eq 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits 0 when backup is stale but startup grace is active (restart scenario)"
    else
        echo "FAIL '${FUNCNAME[0]}': expected exit 0 — startup grace should override stale backup marker"
        return 1
    fi
}

test_healthcheck_no_markers() {
    run_healthcheck \
        "${CROND_START} && ${CRONTAB_SETUP} && /usr/local/bin/healthcheck" \
        -e HEALTHCHECK_SUCCESS_FILE=/tmp/hc-success-absent \
        -e HEALTHCHECK_STARTUP_FILE=/tmp/hc-started-absent \
        && result=0 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero when both startup and success markers are absent"
    else
        echo "FAIL '${FUNCNAME[0]}': expected non-zero exit when no markers exist at all"
        return 1
    fi
}

run_tests() {
    local passed=0
    local tests=(
        test_healthcheck_healthy
        test_healthcheck_no_crontab
        test_healthcheck_crond_down
        test_healthcheck_stale_backup
        test_healthcheck_within_startup_grace
        test_healthcheck_startup_grace_expired
        test_healthcheck_stale_backup_within_startup_grace
        test_healthcheck_no_markers
    )

    setup || { echo "ERROR: Setup failed"; return 1; }

    echo "Running tests for healthcheck..."
    echo "================================="

    for test in "${tests[@]}"; do
        if "${test}"; then (( passed += 1 )) || true; fi
    done

    local failed=$(( ${#tests[@]} - passed ))
    echo "================================="
    echo "Results: ${passed} passed, ${failed} failed"
    return "${failed}"
}

[[ "${BASH_SOURCE[0]}" == "$0" ]] && run_tests
