set -euo pipefail

setup() {
    whereami=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")
    IMAGE=${IMAGE:-1121citrus/pfsense-backup:latest}
    chmod +x "${whereami}/bin/"*

    # Run pfsense-backup with extra docker flags before the image name.
    # Positional args after IMAGE are passed as command arguments.
    run_pfsense_backup() {
        # shellcheck disable=SC2086  # DOCKER_RUN_ARGS is intentionally word-split
        docker run -i --rm ${DOCKER_RUN_ARGS:-} \
            -e "PATH=/test/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
            -e PFSENSE_HOST=fake-host \
            -e PFSENSE_IDENTITY_FILE=/test/fixtures/pfsense-identity.key \
            -e PFSENSE_IDENTITY_PASSWORD=testpassword \
            -v "${whereami}/bin:/test/bin:ro" \
            -v "${whereami}/fixtures:/test/fixtures:ro" \
            "$@" \
            "${IMAGE}" /usr/local/bin/pfsense-backup 2>/dev/null
    }

    # Run pfsense-backup passing CLI arguments to the command (not to docker).
    run_pfsense_backup_args() {
        local cmd_args=("$@")
        # shellcheck disable=SC2086  # DOCKER_RUN_ARGS is intentionally word-split
        docker run -i --rm ${DOCKER_RUN_ARGS:-} \
            -e "PATH=/test/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
            -e PFSENSE_HOST=fake-host \
            -e PFSENSE_IDENTITY_FILE=/test/fixtures/pfsense-identity.key \
            -e PFSENSE_IDENTITY_PASSWORD=testpassword \
            -v "${whereami}/bin:/test/bin:ro" \
            -v "${whereami}/fixtures:/test/fixtures:ro" \
            "${IMAGE}" /usr/local/bin/pfsense-backup "${cmd_args[@]}" 2>/dev/null
    }

    export -f run_pfsense_backup
    export -f run_pfsense_backup_args
}

# ── Required-variable validation ──────────────────────────────────────────────

test_pfsense_backup_missing_host() {
    run_pfsense_backup -e PFSENSE_HOST= -e TAILSCALE_HOST= > /dev/null \
        && result=0 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero when neither PFSENSE_HOST nor TAILSCALE_HOST is set"
    else
        echo "FAIL '${FUNCNAME[0]}': should have exited non-zero"
        return 1
    fi
}

test_pfsense_backup_tailscale_fallback() {
    run_pfsense_backup -e PFSENSE_HOST= -e TAILSCALE_HOST=tailscale-host > /dev/null \
        && result=0 || result=$?
    if [[ ${result} -eq 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': TAILSCALE_HOST accepted when PFSENSE_HOST is unset"
    else
        echo "FAIL '${FUNCNAME[0]}': should have succeeded with TAILSCALE_HOST set"
        return 1
    fi
}

test_pfsense_backup_missing_identity() {
    run_pfsense_backup \
        -e PFSENSE_IDENTITY_FILE=/nonexistent/pfsense.key \
        > /dev/null && result=0 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero when identity file does not exist"
    else
        echo "FAIL '${FUNCNAME[0]}': should have exited non-zero"
        return 1
    fi
}

test_pfsense_backup_missing_password() {
    run_pfsense_backup \
        -e PFSENSE_IDENTITY_PASSWORD= \
        -e PFSENSE_IDENTITY_PASSWORD_FILE=/nonexistent/password \
        > /dev/null && result=0 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero when no password is available"
    else
        echo "FAIL '${FUNCNAME[0]}': should have exited non-zero"
        return 1
    fi
}

# ── XML output ────────────────────────────────────────────────────────────────

test_pfsense_backup_streams_xml() {
    if run_pfsense_backup | grep -q '<?xml'; then
        echo "PASS '${FUNCNAME[0]}': stdout contains XML declaration"
    else
        echo "FAIL '${FUNCNAME[0]}': stdout does not contain XML declaration"
        return 1
    fi
}

test_pfsense_backup_xml_content() {
    local output
    output=$(run_pfsense_backup) && result=0 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "FAIL '${FUNCNAME[0]}': command exited non-zero (${result})"
        return 1
    fi
    local pass=true
    if echo "${output}" | grep -q '<version>24.11</version>'; then
        echo "PASS '${FUNCNAME[0]}': output contains expected version"
    else
        echo "FAIL '${FUNCNAME[0]}': output missing expected version"
        pass=false
    fi
    if echo "${output}" | grep -q '<hostname>test-firewall</hostname>'; then
        echo "PASS '${FUNCNAME[0]}': output contains expected hostname"
    else
        echo "FAIL '${FUNCNAME[0]}': output missing expected hostname"
        pass=false
    fi
    ${pass}
}

test_pfsense_backup_name_file() {
    local tmpdir
    tmpdir=$(mktemp -d)
    run_pfsense_backup \
        -e PFSENSE_BACKUP_NAME_FILE=/name/result \
        -v "${tmpdir}:/name" > /dev/null || {
        echo "FAIL '${FUNCNAME[0]}': command exited non-zero"
        rm -rf "${tmpdir}"
        return 1
    }
    local name
    name=$(cat "${tmpdir}/result" 2>/dev/null) || {
        echo "FAIL '${FUNCNAME[0]}': name file not written"
        rm -rf "${tmpdir}"
        return 1
    }
    rm -rf "${tmpdir}"
    if [[ "${name}" == *"-pfsense-v"*"-config-backup.xml" ]]; then
        echo "PASS '${FUNCNAME[0]}': name file contains expected filename: ${name}"
    else
        echo "FAIL '${FUNCNAME[0]}': unexpected name file contents: '${name}'"
        return 1
    fi
}

# ── CLI flag tests ────────────────────────────────────────────────────────────

test_pfsense_backup_help_flag() {
    local output
    output=$(run_pfsense_backup_args --help 2>&1) && result=0 || result=$?
    if [[ ${result} -eq 0 ]] && echo "${output}" | grep -q 'Usage:'; then
        echo "PASS '${FUNCNAME[0]}': --help exits 0 and prints usage"
    else
        echo "FAIL '${FUNCNAME[0]}': --help did not exit 0 or missing usage text (exit=${result})"
        return 1
    fi
}

test_pfsense_backup_version_flag() {
    run_pfsense_backup_args --version > /dev/null && result=0 || result=$?
    if [[ ${result} -eq 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': --version exits 0"
    else
        echo "FAIL '${FUNCNAME[0]}': --version should exit 0 (got ${result})"
        return 1
    fi
}

test_pfsense_backup_host_flag() {
    run_pfsense_backup_args -H fake-host > /dev/null \
        && result=0 || result=$?
    if [[ ${result} -eq 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': -H flag accepted as host"
    else
        echo "FAIL '${FUNCNAME[0]}': -H flag should have worked (got ${result})"
        return 1
    fi
}

test_pfsense_backup_unknown_option() {
    run_pfsense_backup_args --no-such-option > /dev/null 2>&1 \
        && result=0 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero for unknown option"
    else
        echo "FAIL '${FUNCNAME[0]}': should have exited non-zero for unknown option"
        return 1
    fi
}

run_tests() {
    local passed=0
    local tests=(
        test_pfsense_backup_missing_host
        test_pfsense_backup_tailscale_fallback
        test_pfsense_backup_missing_identity
        test_pfsense_backup_missing_password
        test_pfsense_backup_streams_xml
        test_pfsense_backup_xml_content
        test_pfsense_backup_name_file
        test_pfsense_backup_help_flag
        test_pfsense_backup_version_flag
        test_pfsense_backup_host_flag
        test_pfsense_backup_unknown_option
    )

    setup || { echo "ERROR: Setup failed"; return 1; }

    echo "Running tests for pfsense-backup..."
    echo "====================================="

    for test in "${tests[@]}"; do
        if "${test}"; then (( passed += 1 )) || true; fi
    done

    local failed=$(( ${#tests[@]} - passed ))
    echo "====================================="
    echo "Results: ${passed} passed, ${failed} failed"
    return "${failed}"
}

[[ "${BASH_SOURCE[0]}" == "$0" ]] && run_tests
