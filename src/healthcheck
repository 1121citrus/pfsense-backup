ENV=${ENV:-${HOME:-/root}/.env}
# shellcheck disable=SC1090
[[ -r "${ENV}" ]] && source "${ENV}"

# shellcheck disable=SC1091
source /usr/local/bin/common-functions

set -o errexit -o errtrace -o nounset -o pipefail
set +o xtrace +o verbose
is_true "${DEBUG:-false}" && set -o xtrace -o verbose

HEALTHCHECK_SUCCESS_FILE="${HEALTHCHECK_SUCCESS_FILE:-/tmp/pfsense-backup.last-success}"
HEALTHCHECK_STARTUP_FILE="${HEALTHCHECK_STARTUP_FILE:-/tmp/pfsense-backup.started-at}"
HEALTHCHECK_MAX_AGE_SECONDS="${HEALTHCHECK_MAX_AGE_SECONDS:-172800}"
HEALTHCHECK_STARTUP_GRACE_SECONDS="${HEALTHCHECK_STARTUP_GRACE_SECONDS:-900}"

function epoch_modified() {
    # Return the file's modification time as seconds since epoch.
    # GNU stat (Linux/Alpine) uses -c %Y; BSD stat (macOS) uses -f %m.
    # Trying GNU first and falling back to BSD makes the script portable
    # across both container and macOS development environments.
    local file=$1
    stat -c %Y "${file}" 2>/dev/null || stat -f %m "${file}"
}

function has_cronjob_run() {
    local now
    now=$(date +%s)

    # Both markers are evaluated independently before any error is emitted.
    # This is essential for the container-restart case: a stale success marker
    # may survive on a persistent volume, but the startup file is fresh.
    # Checking grace independently of success prevents an immediate unhealthy
    # result during the grace window, which would otherwise cause Docker to
    # restart the container unnecessarily.
    local fresh_backup=false within_grace=false backup_age='' uptime=''

    if [[ -f "${HEALTHCHECK_SUCCESS_FILE}" ]]; then
        local last_success
        last_success=$(epoch_modified "${HEALTHCHECK_SUCCESS_FILE}")
        backup_age=$((now - last_success))
        (( backup_age <= HEALTHCHECK_MAX_AGE_SECONDS )) && fresh_backup=true
    fi

    if [[ -f "${HEALTHCHECK_STARTUP_FILE}" ]]; then
        local started_at
        started_at=$(epoch_modified "${HEALTHCHECK_STARTUP_FILE}")
        uptime=$((now - started_at))
        (( uptime <= HEALTHCHECK_STARTUP_GRACE_SECONDS )) && within_grace=true
    fi

    # A fresh backup is always healthy.
    "${fresh_backup}" && return 0

    # No fresh backup, but still within the startup grace window is healthy.
    # Handles a container restart where the previous success marker is stale
    # but not enough time has elapsed for a new backup to run.
    "${within_grace}" && return 0

    # Unhealthy — emit the most actionable error available.
    if [[ -n "${backup_age}" ]]; then
        error "latest successful backup is too old: ${backup_age}s > ${HEALTHCHECK_MAX_AGE_SECONDS}s"
    fi
    if [[ -n "${uptime}" ]]; then
        error "startup grace period exceeded (${uptime}s > ${HEALTHCHECK_STARTUP_GRACE_SECONDS}s) with no successful backup"
    fi
    error "missing both startup and successful backup markers"
}

function is_supercronic_running() {
    if pgrep -x supercronic >/dev/null 2>&1; then
        true || info supercronic is running
    else
        error supercronic is not running
    fi
}

function is_crontab_configured() {
    # Read the crontab file directly; supercronic uses a file path, not the
    # OS user crontab managed by crond/crontab(1).
    local crontab_file
    crontab_file="/var/spool/cron/crontabs/$(id -un)"
    if [[ -r "${crontab_file}" ]] && \
            grep -q ' /usr/local/bin/backup 2>&1' "${crontab_file}"; then
        return 0
    else
        error crontab is not configured
    fi
}

function is_healthy() {
    is_crontab_configured && is_supercronic_running && has_cronjob_run
}

is_healthy || exit 1

