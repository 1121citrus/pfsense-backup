set -o errexit -o errtrace -o nounset -o pipefail
set +o xtrace +o verbose

ENV=${ENV:-${HOME:-/root}/.env}
# shellcheck disable=SC1090
[[ -r "${ENV}" ]] && source "${ENV}"

# shellcheck disable=SC1090
source /usr/local/bin/common-functions

if is_true "${DEBUG:-false}"; then set -o xtrace -o verbose; fi

# crond runs jobs with a minimal environment (just PATH and a few system
# vars).  Write all runtime configuration to ~/.env so each job can source
# it on startup and get the full variable set.  This is simpler than
# threading variables through crond's own ENVFILE mechanism.
#
# __quote handles embedded single quotes in variable values by replacing
# each ' with '"'"' — the standard shell quoting idiom — so the generated
# export statements remain syntactically valid when sourced.
__quote() { printf '%s' "${1//\'/\'\"\'\"\'}" ; }
cat <<EOF >"${ENV}"
export AWS_CONFIG_FILE='$(__quote "${AWS_CONFIG_FILE:-/run/secrets/aws-config}")'
export AWS_DRYRUN='$(__quote "${AWS_DRYRUN:-false}")'
export AWS_S3_BUCKET_NAME='$(__quote "${AWS_S3_BUCKET_NAME:?Need bucket}")'
export COMPRESSION='$(__quote "${COMPRESSION:-none}")'
export CRON_EXPRESSION='$(__quote "${CRON_EXPRESSION:-@daily}")'
export DEBUG='$(__quote "${DEBUG:-false}")'
export GPG_CIPHER_ALGO='$(__quote "${GPG_CIPHER_ALGO:-aes256}")'
export GPG_PASSPHRASE='$(__quote "${GPG_PASSPHRASE:-}")'
export GPG_PASSPHRASE_FILE='$(__quote "${GPG_PASSPHRASE_FILE:-/run/secrets/gpg-passphrase}")'
export HEALTHCHECK_MAX_AGE_SECONDS='$(__quote "${HEALTHCHECK_MAX_AGE_SECONDS:-172800}")'
export HEALTHCHECK_STARTUP_FILE='$(__quote "${HEALTHCHECK_STARTUP_FILE:-/tmp/pfsense-backup.started-at}")'
export HEALTHCHECK_STARTUP_GRACE_SECONDS='$(__quote "${HEALTHCHECK_STARTUP_GRACE_SECONDS:-900}")'
export HEALTHCHECK_SUCCESS_FILE='$(__quote "${HEALTHCHECK_SUCCESS_FILE:-/tmp/pfsense-backup.last-success}")'
export PFSENSE_HOST='$(__quote "${PFSENSE_HOST:-}")'
export PFSENSE_USER='$(__quote "${PFSENSE_USER:-}")'
export PFSENSE_IDENTITY_FILE='$(__quote "${PFSENSE_IDENTITY_FILE:-/run/secrets/pfsense-identity}")'
export PFSENSE_IDENTITY_PASSWORD='$(__quote "${PFSENSE_IDENTITY_PASSWORD:-}")'
export PFSENSE_IDENTITY_PASSWORD_FILE='$(__quote "${PFSENSE_IDENTITY_PASSWORD_FILE:-/run/secrets/pfsense-identity-password}")'
export PFSENSE_SSH_KNOWN_HOSTS_FILE='$(__quote "${PFSENSE_SSH_KNOWN_HOSTS_FILE:-/root/.ssh/known_hosts}")'
export PFSENSE_SSH_STRICT_HOST_KEY_CHECKING='$(__quote "${PFSENSE_SSH_STRICT_HOST_KEY_CHECKING:-accept-new}")'
export RSA_PUBLIC_KEY_FILE='$(__quote "${RSA_PUBLIC_KEY_FILE:=/run/secrets/rsa-public-key}")'
export TAILSCALE_HOST='$(__quote "${TAILSCALE_HOST:-}")'
export TZ='$(__quote "${TZ:-UTC}")'
EOF
# clean-credentials redacts sensitive values before logging the .env
# contents.  GPG_PASSPHRASE and PFSENSE_IDENTITY_PASSWORD are replaced with
# **REDACTED** so secrets are never written to Docker logs.
clean-credentials() {
    sed -E 's/(GPG_PASSPHRASE|PFSENSE_IDENTITY_PASSWORD)='"'"'.*'"'"'$/\1='"'**REDACTED**'"'/'
}
info "create env file ${ENV}"
chmod -c 0600 "${ENV}" | info
clean-credentials < "${ENV}" | info
# shellcheck disable=SC1090
source "${ENV}"

# Touch the startup marker now so the healthcheck can distinguish a freshly
# started container (within grace window) from one where the backup is
# genuinely overdue.  See src/healthcheck: has_cronjob_run().
touch "${HEALTHCHECK_STARTUP_FILE}"

# Write the crontab and hand off to crond as PID 1.
# crond -l 2 sets log level 2 (notice); -f runs in the foreground.
COMMAND=${COMMAND:-/usr/local/bin/backup}
info "installing cron.d entry: ${COMMAND}"
(mkdir -pv /var/spool/cron/crontabs && chmod -c 0755 /var/spool/cron/crontabs) | info
echo "${CRON_EXPRESSION} ${COMMAND} 2>&1" > /var/spool/cron/crontabs/root && chmod -c 0600 /var/spool/cron/crontabs/root | info
info "crontab: $(cat /var/spool/cron/crontabs/root)"

info "handing the reins over to cron daemon"
crond -l 2 -f
