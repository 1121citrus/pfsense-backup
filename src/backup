# ~/.env is how the startup encodes arguments to be accessed by this command in cron job
ENV=${ENV:-${HOME:-/root}/.env}
# shellcheck disable=SC1090
[[ -r "${ENV}" ]] && source "${ENV}"

# shellcheck disable=SC1090
source /usr/local/bin/common-functions

HEALTHCHECK_SUCCESS_FILE="${HEALTHCHECK_SUCCESS_FILE:-/tmp/pfsense-backup.last-success}"

set -o errexit -o errtrace -o nounset -o pipefail
set +o xtrace +o verbose
is_true "${DEBUG:=false}" && set -o xtrace -o verbose

command=$(basename "${0}")

# Create a work directory -- to cleanup any debris
workdir=$(mktemp -d)
# shellcheck disable=SC2329
cleanup() {
    rm -rf "${workdir}" >/dev/null 2>&1 || true
}
trap 'cleanup' EXIT
cd "${workdir}"

export AWS_CONFIG_FILE="${AWS_CONFIG_FILE:=/run/secrets/aws-config}"

bucket="${AWS_S3_BUCKET_NAME:=}"
[[ -n "${bucket}" ]] || error 'need AWS_S3_BUCKET_NAME'
dryrun="${AWS_DRYRUN:=false}"
# pfSense host OR IP (note: do not include the final /, otherwise backup will fail)
internal_gateway=$(traceroute -m 1 1.1.1.1 2>/dev/null | head -1 | sed -E 's/.* [(]([^)]*)[)].*/\1/' || true)
host="${PFSENSE_HOST:-${TAILSCALE_HOST:-${internal_gateway}}}"
[[ -n "${host}" ]] || error 'need PFSENSE_HOST or TAILSCALE_HOST'
identity_file="${PFSENSE_IDENTITY_FILE:=/run/secrets/pfsense-identity}"
[[ -n "${identity_file}" ]] || error 'need PFSENSE_IDENTITY_FILE (default: /run/secrets/pfsense-identity)'
[[ -r "${identity_file}" ]] || error "${identity_file} not found or is not readable"
# Restrict key file permissions.  Warn rather than fail: Docker secrets are
# mounted read-only (0400 root:root) so chmod succeeds on a rw bind-mount but
# may fail on a read-only mount — both are acceptable.
chmod 600 "${identity_file}" 2>/dev/null || \
    debug "unable to set permissions on '${identity_file}' (read-only mount?)"
user="${PFSENSE_USER:=remote-backup}"

# don't use ssh config file; no pty 
strict_host_key_checking="${PFSENSE_SSH_STRICT_HOST_KEY_CHECKING:=accept-new}"
known_hosts_file="${PFSENSE_SSH_KNOWN_HOSTS_FILE:=/root/.ssh/known_hosts}"
if [[ "${strict_host_key_checking}" == "no" ]]; then
    known_hosts_arg="UserKnownHostsFile=/dev/null"
else
    touch "${known_hosts_file}"
    chmod 600 "${known_hosts_file}" 2>/dev/null || \
        debug "unable to set permissions on '${known_hosts_file}'"
    known_hosts_arg="UserKnownHostsFile=${known_hosts_file}"
fi
ssh_args=(
    -F /dev/null
    -T
    -o LogLevel=quiet
    -o "StrictHostKeyChecking=${strict_host_key_checking}"
    -o "${known_hosts_arg}"
)
if [[ -n "${PFSENSE_EXTRA_SSH_ARGS:-}" ]]; then
    read -r -a ssh_extra_args <<< "${PFSENSE_EXTRA_SSH_ARGS}"
    ssh_args+=("${ssh_extra_args[@]}")
fi
sshpass_args=(-P passphrase)
if [[ -n "${PFSENSE_EXTRA_SSHPASS_ARGS:=}" ]]; then
    read -r -a sshpass_extra_args <<< "${PFSENSE_EXTRA_SSHPASS_ARGS}"
    sshpass_args+=("${sshpass_extra_args[@]}")
fi
if is_true "${DEBUG}"; then
    ssh_args=(-v "${ssh_args[@]}")
    sshpass_args=(-v "${sshpass_args[@]}")
fi

have_password=false
PFSENSE_IDENTITY_PASSWORD="${PFSENSE_IDENTITY_PASSWORD:=}"
if [[ -n "${PFSENSE_IDENTITY_PASSWORD}" ]]; then
    # NOTE: -p passes the passphrase as a command-line argument, which is
    # briefly visible in /proc/<pid>/cmdline while sshpass is running.
    # Prefer PFSENSE_IDENTITY_PASSWORD_FILE (Docker secret) for production use.
    sshpass_args+=( -p "${PFSENSE_IDENTITY_PASSWORD}" )
    have_password=true
elif [[ -r "${PFSENSE_IDENTITY_PASSWORD_FILE:=/run/secrets/pfsense-identity-password}" ]]; then
    chmod 600 "${PFSENSE_IDENTITY_PASSWORD_FILE}" 2>/dev/null || \
        debug "unable to set permissions on '${PFSENSE_IDENTITY_PASSWORD_FILE}' (read-only mount?)"
    sshpass_args+=( -f "${PFSENSE_IDENTITY_PASSWORD_FILE}" )
    have_password=true
fi
${have_password} || error 'need PFSENSE_IDENTITY_PASSWORD or PFSENSE_IDENTITY_PASSWORD_FILE (default: /run/secrets/pfsense-identity-password)'

gpg_encrypt=false
gpg_args=(--symmetric --cipher-algo "${GPG_CIPHER_ALGO:=aes256}" --batch)
if [[ -n "${GPG_PASSPHRASE:=}" ]]; then
    gpg_args+=(--passphrase "${GPG_PASSPHRASE}")
    gpg_encrypt=true
elif [[ -r "${GPG_PASSPHRASE_FILE:=/run/secrets/gpg-passphrase}" ]]; then
    chmod 600 "${GPG_PASSPHRASE_FILE}" 2>/dev/null || \
        debug "unable to set permissions on '${GPG_PASSPHRASE_FILE}' (read-only mount?)"
    gpg_args+=(--passphrase-file "${GPG_PASSPHRASE_FILE}")
    gpg_encrypt=true
fi

openssl_rsa_encrypt=false
# if [[ -r "${RSA_PUBLIC_KEY_FILE:=/run/secrets/rsa-public-key}" ]]; then
#     error "RSA_PUBLIC_KEY_FILE not implemented - check back later"
#     chmod 600 "${RSA_PUBLIC_KEY_FILE}" 2>/dev/null || true
#     openssl_rsa_encrypt=true
# fi

"${gpg_encrypt}" && "${openssl_rsa_encrypt}" && \
    error "symmetric gpg and asymmetric RSA encryption cannot be used together"

info "begin ${command}"

config_tmp=$(mktemp)
if ! sshpass "${sshpass_args[@]}" ssh "${ssh_args[@]}" \
    -l "${user}" \
    -i "${identity_file}" \
    "${host}" > "${config_tmp}"; then
    debug "ssh configuration download failed for user='${user}' host='${host}'"
    error "configuration download failed"
fi

version=$(grep -m1 '<version' "${config_tmp}" | cut -f2 -d">" | cut -f1 -d"<" || true)
[[ -n "${version}" ]] || error 'invalid pfSense configuration file - missing version'
hostname=$(grep -m1 '<hostname' "${config_tmp}" | cut -f2 -d">" | cut -f1 -d"<" || true)
[[ -n "${hostname}" ]] || error 'invalid pfSense configuration file - missing hostname'
domain=$(grep -m1 '<domain' "${config_tmp}" | cut -f2 -d">" | cut -f1 -d"<" || true)
[[ -n "${domain}" ]] || error 'invalid pfSense configuration file - missing domain'
# Sanitize values extracted from XML before embedding them in the filename.
# Allow only alphanumeric characters, hyphens, underscores, and dots.  Any
# other character (including path separators) is replaced with a hyphen.  This
# prevents directory traversal and filename-injection via a crafted config file.
hostname="${hostname//[^a-zA-Z0-9._-]/-}"
version="${version//[^a-zA-Z0-9._-]/-}"
backup_file="$(date +%Y%m%dT%H%M%S)-${hostname}-pfsense-v${version}-config-backup.xml"

# Add header to pulled XML file
(echo '<?xml version="1.0" encoding="UTF-8"?>' && \
 echo "<!-- ${backup_file} -->" && \
 tail -n +2 "${config_tmp}") > "${backup_file}"
output_file="${backup_file}"

case "${COMPRESSION:=none}" in
    bzip | bzip2)
        info "compressing backup with bzip2: ${output_file}.bz2"
        bzip2 -9 --keep --quiet --stdout  <"${output_file}" >"${output_file}.bz2"
        output_file="${output_file}.bz2"
        ;;
 
    bzip3)
        info "compressing backup with bzip3: ${output_file}.bz3"
        bzip3 --batch --keep --stdout "${output_file}" >"${output_file}.bz3"
        output_file="${output_file}.bz3"
        ;;
 
    gz | gzip)
        info "compressing backup with gzip --best --no-name --quiet --synchronous: ${output_file}.gz"
        gzip --best --no-name --quiet --synchronous <"${output_file}" >"${output_file}.gz"
        output_file="${output_file}.gz"
        ;;

    lzo | lzop)
        info "compressing backup with lzop: ${output_file}.lzo"
        lzop <"${output_file}" >"${output_file}.lzo"
        output_file="${output_file}.lzo"
        ;;

    none)
        true
        ;;

    lzma | xz)
        info "compressing backup with lzma/xz --compress --extreme --quiet: ${output_file}.xz"
        xz --compress --extreme --quiet <"${output_file}" >"${output_file}.xz"
        output_file="${output_file}.xz"
        ;;

    pigz)
        info "compressing backup with pigz --best --no-name --quiet --synchronous: ${output_file}.pgz"
        pigz --best --no-name --quiet --synchronous <"${output_file}" >"${output_file}.pgz"
        output_file="${output_file}.pgz"
        ;;

    pixz)
        info "compressing backup with pixz -9 -t: ${output_file}.pxz"
        pixz -9 -t <"${output_file}" >"${output_file}.pxz"
        output_file="${output_file}.pxz"
        ;;

    zip)
        info "compressing backup with zip -q -9: ${output_file}.zip"
        zip -q -9 "${output_file}.zip" "${output_file}"
        output_file="${output_file}.zip"
        ;;

    *)
        error "unknown compression algorithm: '${COMPRESSION}'"
        ;;
esac

if "${gpg_encrypt}"; then
    info "encrypting backup with GPG"
    gpg "${gpg_args[@]}" --output "${output_file}.gpg" "${output_file}"
    output_file="${output_file}.gpg"
fi

# if "${openssl_rsa_encrypt}"; then
#     info "encrypting backup with RSA public key"
#     openssl rsautl -encrypt \
#                    -pubin \
#                    -inkey <(ssh-keygen -f "${RSA_PUBLIC_KEY_FILE}" -e -m 'PKCS8') \
#                    -ssl \
#                    -in "${output_file}" \
#                    -out "${output_file}.enc"
#     output_file="${output_file}.enc"
# fi

info "downloaded '${backup_file}' to '${output_file}'"

awsargs=(--no-progress)
is_true "${dryrun}" && awsargs+=(--dryrun)

info "begin mv '${output_file}' to S3 bucket '${bucket}'"
uri="s3://${bucket}/${output_file}"
info "running aws s3 mv ${awsargs[*]} ${output_file} ${uri}"
# Pipe aws output through info for structured logging.  With set -o pipefail a
# non-zero aws exit propagates through the pipeline; the || branch fires only on
# failure and provides a clear error message before the script exits.
# IMPORTANT: touch the healthcheck marker only after a confirmed successful
# upload — never before, never on failure.
aws s3 mv "${awsargs[@]}" "${output_file}" "${uri}" 2>&1 | info || \
    error "aws s3 mv failed uploading '${output_file}' to '${uri}'"
info "completed aws s3 mv ${awsargs[*]} ${output_file} ${uri}"
touch "${HEALTHCHECK_SUCCESS_FILE}" 2>/dev/null || true
info "finish ${command}"
exit 0

