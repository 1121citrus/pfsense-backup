# Compatibility shim — retained for deployments that set
#   entrypoint: /usr/local/bin/startup
# Use 'pfsense-backup --cron' directly in new deployments.
#
# Require a bucket: when invoked as 'backup', S3 upload is mandatory.
# CLI --bucket/--bucket-list flags also satisfy this check.
_has_bucket=false
[[ -n "${AWS_S3_BUCKET_NAME:-}${BUCKET:-}${BUCKET_LIST:-}" ]] && _has_bucket=true
for _arg in "$@"; do
    case "${_arg}" in --bucket|--bucket-list|-b) _has_bucket=true; break ;; esac
done
if ! "${_has_bucket}"; then
    echo "[ERROR] backup: need AWS_S3_BUCKET_NAME, BUCKET, or --bucket" >&2
    exit 1
fi
unset _has_bucket _arg
PFSENSE_BACKUP_COMMAND=backup exec /usr/local/bin/pfsense-backup "$@"
