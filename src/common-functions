# Resolve include root.
# Priority:
# 1) INCLUDE_DIR (for tests and overrides)
# 2) /usr/local/include (runtime default)
# 3) repo-local include/ (for host-side coverage tests via symlinked sources)
_common_include_root="${INCLUDE_DIR:-/usr/local/include}"

if [[ ! -r "${_common_include_root}/logging" ]] || \
   [[ ! -r "${_common_include_root}/path" ]]; then
    _common_this_file="${BASH_SOURCE[0]}"
    if command -v realpath >/dev/null 2>&1; then
        _common_this_file="$(realpath "${_common_this_file}" 2>/dev/null || echo "${_common_this_file}")"
    elif readlink -f "${_common_this_file}" >/dev/null 2>&1; then
        _common_this_file="$(readlink -f "${_common_this_file}" 2>/dev/null || echo "${_common_this_file}")"
    fi

    _common_repo_root="$(cd "$(dirname "${_common_this_file}")/.." >/dev/null 2>&1 && pwd)"
    if [[ -r "${_common_repo_root}/include/logging" ]] && \
       [[ -r "${_common_repo_root}/include/path" ]]; then
        _common_include_root="${_common_repo_root}/include"
    fi
fi

# shellcheck disable=SC1090
source "${_common_include_root}/logging"
# shellcheck disable=SC1090
source "${_common_include_root}/path"

# Legacy behavior compatibility: historical common-functions logged DEBUG
# messages without requiring LOG_LEVEL to be set.
if [[ -z "${LOG_LEVEL:-}" ]]; then
    export LOG_LEVEL=debug
fi

function is_true() {
    is-true "${1:-}"
}

function is_false() {
    is-false "${1:-}"
}

function touch_healthcheck_startup_marker() {
    [[ -n "${HEALTHCHECK_STARTUP_FILE:-}" ]] && touch "${HEALTHCHECK_STARTUP_FILE}"
    return 0
}

unset _common_include_root _common_repo_root _common_this_file